<?xml version="1.0" encoding="UTF-8"?>
<entity-facade-xml type="seed" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-facade-xml-3.xsd">

    <!-- ========================================================= -->
    <!-- Pre-requisite Seed Data (Fallback)                        -->
    <!-- ========================================================= -->
    <mantle.party.RoleType roleTypeId="InternalOrganization" description="Internal Organization"/>
    <mantle.party.RoleType roleTypeId="Issuer" description="Issuer"/>
    <mantle.party.RoleType roleTypeId="Customer" description="Customer"/>
    <mantle.party.RoleType roleTypeId="Bank" description="Bank"/>
    <mantle.party.RoleType roleTypeId="Vendor" description="Vendor"/>


    <!-- ========================================================= -->
    <!-- Status Types                                              -->
    <!-- ========================================================= -->

    <!-- LC Lifecycle Status Type -->
    <moqui.basic.StatusType statusTypeId="LcLifecycle" description="LC Lifecycle Status"/>
    <!-- LC Transaction Processing Status Type -->
    <moqui.basic.StatusType statusTypeId="LcTransaction" description="LC Transaction Processing Status"/>
    <!-- LC Drawing Status Type -->
    <moqui.basic.StatusType statusTypeId="LcDrawingStatus" description="LC Drawing Status"/>
    <!-- LC Provision Status Type -->
    <moqui.basic.StatusType statusTypeId="LcProvisionStatus" description="LC Provision Status"/>
    <!-- LC Amendment Confirmation Status Type -->
    <moqui.basic.StatusType statusTypeId="LcAmendmentConfirmation" description="LC Amendment Confirmation Status"/>
    <!-- LC Provision Collection Status Type -->
    <moqui.basic.StatusType statusTypeId="LcProvisionCollection" description="LC Provision Collection Status"/>
    <!-- LC Provision Collection Entry Status Type -->
    <moqui.basic.StatusType statusTypeId="LcProvisionCollectionEntry" description="LC Provision Collection Entry Status"/>


    <!-- ========================================================= -->
    <!-- LC Lifecycle Status Items & Flow                          -->
    <!-- Tracks the actual instrument state of the LC              -->
    <!-- ========================================================= -->
    <moqui.basic.StatusFlow statusFlowId="LcLifecycle" description="LC Lifecycle Flow"/>

    <moqui.basic.StatusItem statusId="LcLfDraft" statusTypeId="LcLifecycle" description="Draft" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcLfApplied" statusTypeId="LcLifecycle" description="Applied" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcLfIssued" statusTypeId="LcLifecycle" description="Issued" sequenceNum="3"/>
    <moqui.basic.StatusItem statusId="LcLfAdvised" statusTypeId="LcLifecycle" description="Advised" sequenceNum="4"/>
    <moqui.basic.StatusItem statusId="LcLfAmended" statusTypeId="LcLifecycle" description="Amended" sequenceNum="5"/>
    <moqui.basic.StatusItem statusId="LcLfNegotiated" statusTypeId="LcLifecycle" description="Negotiated" sequenceNum="6"/>
    <moqui.basic.StatusItem statusId="LcLfRevoked" statusTypeId="LcLifecycle" description="Revoked" sequenceNum="7"/>
    <moqui.basic.StatusItem statusId="LcLfExpired" statusTypeId="LcLifecycle" description="Expired" sequenceNum="8"/>
    <moqui.basic.StatusItem statusId="LcLfClosed" statusTypeId="LcLifecycle" description="Closed" sequenceNum="9"/>

    <!-- LC Lifecycle StatusFlow Transitions -->
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfDraft"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfApplied"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfIssued"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfAdvised"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfAmended"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfNegotiated"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfRevoked"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfExpired"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcLifecycle" statusId="LcLfClosed"/>

    <!-- Valid Transitions: Draft -> Applied -> Issued -> Advised/Amended/Negotiated/Expired/Closed -->
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfDraft" toStatusId="LcLfApplied" transitionName="Apply"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfApplied" toStatusId="LcLfIssued" transitionName="Issue"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfIssued" toStatusId="LcLfAdvised" transitionName="Advise"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfIssued" toStatusId="LcLfAmended" transitionName="Amend"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfIssued" toStatusId="LcLfNegotiated" transitionName="Negotiate"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfIssued" toStatusId="LcLfRevoked" transitionName="Revoke"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfIssued" toStatusId="LcLfExpired" transitionName="Expire"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfIssued" toStatusId="LcLfClosed" transitionName="Close"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAdvised" toStatusId="LcLfAmended" transitionName="Amend"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAdvised" toStatusId="LcLfNegotiated" transitionName="Negotiate"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAdvised" toStatusId="LcLfExpired" transitionName="Expire"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAdvised" toStatusId="LcLfClosed" transitionName="Close"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAmended" toStatusId="LcLfAmended" transitionName="Amend Again"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAmended" toStatusId="LcLfRevoked" transitionName="Revoke"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAmended" toStatusId="LcLfNegotiated" transitionName="Negotiate"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAmended" toStatusId="LcLfExpired" transitionName="Expire"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcLifecycle" statusId="LcLfAmended" toStatusId="LcLfClosed" transitionName="Close"/>

    <!-- ========================================================= -->
    <!-- LC Transaction Processing Status Items & Flow             -->
    <!-- Tracks the internal processing state of each request      -->
    <!-- ========================================================= -->
    <moqui.basic.StatusFlow statusFlowId="LcTransaction" description="LC Transaction Processing Flow"/>

    <moqui.basic.StatusItem statusId="LcTxDraft" statusTypeId="LcTransaction" description="Draft" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcTxPendingReview" statusTypeId="LcTransaction" description="Pending Review" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcTxPendingProcessing" statusTypeId="LcTransaction" description="Pending Processing" sequenceNum="3"/>
    <moqui.basic.StatusItem statusId="LcTxReturned" statusTypeId="LcTransaction" description="Returned" sequenceNum="3.5"/>
    <moqui.basic.StatusItem statusId="LcTxSubmitted" statusTypeId="LcTransaction" description="Submitted" sequenceNum="4"/>
    <moqui.basic.StatusItem statusId="LcTxPendingApproval" statusTypeId="LcTransaction" description="Pending Approval" sequenceNum="5"/>
    <moqui.basic.StatusItem statusId="LcTxApproved" statusTypeId="LcTransaction" description="Approved" sequenceNum="6"/>
    <moqui.basic.StatusItem statusId="LcTxRejected" statusTypeId="LcTransaction" description="Rejected" sequenceNum="7"/>
    <moqui.basic.StatusItem statusId="LcTxCancelled" statusTypeId="LcTransaction" description="Cancelled" sequenceNum="8"/>
    <moqui.basic.StatusItem statusId="LcTxClosed" statusTypeId="LcTransaction" description="Closed" sequenceNum="9"/>
    <!-- Amendment workflow statuses -->
    <moqui.basic.StatusItem statusId="LcTxSupervisorApproved" statusTypeId="LcTransaction" description="Supervisor Approved" sequenceNum="4.5"/>
    <moqui.basic.StatusItem statusId="LcTxIpcApproved" statusTypeId="LcTransaction" description="IPC Approved" sequenceNum="4.6"/>

    <!-- LC Transaction StatusFlow Transitions -->
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxDraft"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxPendingReview"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxPendingProcessing"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxReturned"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxSubmitted"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxPendingApproval"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxApproved"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxRejected"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxCancelled"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxClosed"/>
    <!-- Amendment workflow status flow items -->
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxSupervisorApproved"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcTransaction" statusId="LcTxIpcApproved"/>

    <!-- Valid Transitions: Draft -> Submitted -> Approved/Rejected, Approved -> Closed -->
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxDraft" toStatusId="LcTxSubmitted" transitionName="Submit"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxSubmitted" toStatusId="LcTxSupervisorApproved" transitionName="Supervisor Approve"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxSubmitted" toStatusId="LcTxRejected" transitionName="Reject"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxSubmitted" toStatusId="LcTxReturned" transitionName="Return"/>
    
    <!-- Amendment workflow: Supervisor -> IPC -> Approved -->
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxSupervisorApproved" toStatusId="LcTxIpcApproved" transitionName="IPC Approve"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxSupervisorApproved" toStatusId="LcTxRejected" transitionName="Supervisor Reject"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxIpcApproved" toStatusId="LcTxApproved" transitionName="Final Approve"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxIpcApproved" toStatusId="LcTxRejected" transitionName="IPC Reject"/>

    <!-- Valid Transitions: Draft -> Pending Review -> Pending Processing -> Pending Approval -> Approved -->
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxDraft" toStatusId="LcTxPendingReview" transitionName="Submit for Review"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingReview" toStatusId="LcTxPendingProcessing" transitionName="Submit for Processing"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingReview" toStatusId="LcTxApproved" transitionName="Approve Directly" transitionId="LcTxPendingReviewApproved"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingReview" toStatusId="LcTxReturned" transitionName="Return"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingProcessing" toStatusId="LcTxPendingApproval" transitionName="Submit for Approval"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingProcessing" toStatusId="LcTxReturned" transitionName="Return"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingProcessing" toStatusId="LcTxPendingReview" transitionName="Return to Review"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingApproval" toStatusId="LcTxApproved" transitionName="Approve"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingApproval" toStatusId="LcTxRejected" transitionName="Reject"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingApproval" toStatusId="LcTxReturned" transitionName="Return"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxPendingApproval" toStatusId="LcTxPendingReview" transitionName="Return to Review"/>
    
    <!-- Backward compatibility and fallback -->
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxDraft" toStatusId="LcTxCancelled" transitionName="Cancel"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxApproved" toStatusId="LcTxClosed" transitionName="Close"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxRejected" toStatusId="LcTxDraft" transitionName="Reopen"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcTransaction" statusId="LcTxReturned" toStatusId="LcTxDraft" transitionName="Edit and Re-submit"/>

    <!-- ========================================================= -->
    <!-- LC Drawing Status Items & Flow                            -->
    <!-- ========================================================= -->
    <moqui.basic.StatusFlow statusFlowId="LcDrawingStatus" description="LC Drawing Status Flow"/>

    <moqui.basic.StatusItem statusId="LcDrReceived" statusTypeId="LcDrawingStatus" description="Received" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcDrCompliant" statusTypeId="LcDrawingStatus" description="Compliant" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcDrDiscrepant" statusTypeId="LcDrawingStatus" description="Discrepant" sequenceNum="3"/>
    <moqui.basic.StatusItem statusId="LcDrAccepted" statusTypeId="LcDrawingStatus" description="Accepted" sequenceNum="4"/>
    <moqui.basic.StatusItem statusId="LcDrUnderTrust" statusTypeId="LcDrawingStatus" description="Under Trust" sequenceNum="5"/>
    <moqui.basic.StatusItem statusId="LcDrPaid" statusTypeId="LcDrawingStatus" description="Paid" sequenceNum="6"/>
    <moqui.basic.StatusItem statusId="LcDrRejected" statusTypeId="LcDrawingStatus" description="Rejected" sequenceNum="7"/>

    <!-- Drawing StatusFlow Transitions -->
    <moqui.basic.StatusFlowItem statusFlowId="LcDrawingStatus" statusId="LcDrReceived"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcDrawingStatus" statusId="LcDrCompliant"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcDrawingStatus" statusId="LcDrDiscrepant"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcDrawingStatus" statusId="LcDrAccepted"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcDrawingStatus" statusId="LcDrUnderTrust"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcDrawingStatus" statusId="LcDrPaid"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcDrawingStatus" statusId="LcDrRejected"/>

    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrReceived" toStatusId="LcDrCompliant" transitionName="Mark Compliant"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrReceived" toStatusId="LcDrDiscrepant" transitionName="Mark Discrepant"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrCompliant" toStatusId="LcDrAccepted" transitionName="Accept"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrCompliant" toStatusId="LcDrPaid" transitionName="Pay"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrDiscrepant" toStatusId="LcDrAccepted" transitionName="Accept Discrepancy"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrDiscrepant" toStatusId="LcDrRejected" transitionName="Reject"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrDiscrepant" toStatusId="LcDrUnderTrust" transitionName="Release Under Trust"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrAccepted" toStatusId="LcDrPaid" transitionName="Pay"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcDrawingStatus" statusId="LcDrUnderTrust" toStatusId="LcDrPaid" transitionName="Pay"/>

    <!-- ========================================================= -->
    <!-- LC Provision Status Items                                 -->
    <!-- ========================================================= -->
    <moqui.basic.StatusItem statusId="LcPrvDraft" statusTypeId="LcProvisionStatus" description="Draft" sequenceNum="0"/>
    <moqui.basic.StatusItem statusId="LcPrvHeld" statusTypeId="LcProvisionStatus" description="Funds Held" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcPrvActive" statusTypeId="LcProvisionStatus" description="Active" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcPrvReleased" statusTypeId="LcProvisionStatus" description="Released" sequenceNum="3"/>

    <!-- ========================================================= -->
    <!-- LC Amendment Confirmation Status Items & Flow             -->
    <!-- ========================================================= -->
    <moqui.basic.StatusFlow statusFlowId="LcAmendmentConfirmation" description="LC Amendment Confirmation Flow"/>

    <moqui.basic.StatusItem statusId="LcAmndPending" statusTypeId="LcAmendmentConfirmation" description="Pending Confirmation" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcAmndConfirmed" statusTypeId="LcAmendmentConfirmation" description="Confirmed" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcAmndRejected" statusTypeId="LcAmendmentConfirmation" description="Rejected" sequenceNum="3"/>

    <moqui.basic.StatusFlowItem statusFlowId="LcAmendmentConfirmation" statusId="LcAmndPending"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcAmendmentConfirmation" statusId="LcAmndConfirmed"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcAmendmentConfirmation" statusId="LcAmndRejected"/>

    <moqui.basic.StatusFlowTransition statusFlowId="LcAmendmentConfirmation" statusId="LcAmndPending" toStatusId="LcAmndConfirmed" transitionName="Confirm Amendment"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcAmendmentConfirmation" statusId="LcAmndPending" toStatusId="LcAmndRejected" transitionName="Reject Amendment"/>

    <!-- ========================================================= -->
    <!-- LC Provision Collection Status Items                       -->
    <!-- ========================================================= -->
    <moqui.basic.StatusFlow statusFlowId="LcProvisionCollection" description="LC Provision Collection Flow"/>

    <moqui.basic.StatusItem statusId="LcPrvColDraft" statusTypeId="LcProvisionCollection" description="Draft" sequenceNum="0"/>
    <moqui.basic.StatusItem statusId="LcPrvColComplete" statusTypeId="LcProvisionCollection" description="Complete" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcPrvColCollected" statusTypeId="LcProvisionCollection" description="Collected" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcPrvColReleased" statusTypeId="LcProvisionCollection" description="Released" sequenceNum="3"/>
    <moqui.basic.StatusItem statusId="LcPrvColFailed" statusTypeId="LcProvisionCollection" description="Failed" sequenceNum="4"/>

    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollection" statusId="LcPrvColDraft"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollection" statusId="LcPrvColComplete"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollection" statusId="LcPrvColCollected"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollection" statusId="LcPrvColReleased"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollection" statusId="LcPrvColFailed"/>

    <!-- LC Provision Collection Entry Status Items -->
    <moqui.basic.StatusItem statusId="LcPrvColEntPending" statusTypeId="LcProvisionCollectionEntry" description="Pending" sequenceNum="0"/>
    <moqui.basic.StatusItem statusId="LcPrvColEntApplied" statusTypeId="LcProvisionCollectionEntry" description="Applied" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcPrvColEntFailed" statusTypeId="LcProvisionCollectionEntry" description="Failed" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcPrvColEntReversed" statusTypeId="LcProvisionCollectionEntry" description="Reversed" sequenceNum="3"/>

    <!-- Collection StatusFlow Transitions -->
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollection" statusId="LcPrvColDraft" toStatusId="LcPrvColComplete" transitionName="Complete Collection"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollection" statusId="LcPrvColDraft" toStatusId="LcPrvColFailed" transitionName="Fail Collection"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollection" statusId="LcPrvColComplete" toStatusId="LcPrvColCollected" transitionName="Collect Funds"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollection" statusId="LcPrvColCollected" toStatusId="LcPrvColReleased" transitionName="Release Funds"/>

    <!-- ========================================================= -->
    <!-- LC Provision Collection Entry Status Items                -->
    <!-- ========================================================= -->
    <moqui.basic.StatusFlow statusFlowId="LcProvisionCollectionEntry" description="LC Provision Collection Entry Flow"/>

    <moqui.basic.StatusItem statusId="LcPrvEntryPending" statusTypeId="LcProvisionCollectionEntry" description="Pending" sequenceNum="0"/>
    <moqui.basic.StatusItem statusId="LcPrvEntryCollected" statusTypeId="LcProvisionCollectionEntry" description="Collected" sequenceNum="1"/>
    <moqui.basic.StatusItem statusId="LcPrvEntryReleased" statusTypeId="LcProvisionCollectionEntry" description="Released" sequenceNum="2"/>
    <moqui.basic.StatusItem statusId="LcPrvEntryFailed" statusTypeId="LcProvisionCollectionEntry" description="Failed" sequenceNum="3"/>

    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryPending"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryCollected"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryReleased"/>
    <moqui.basic.StatusFlowItem statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryFailed"/>

    <!-- Entry StatusFlow Transitions -->
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryPending" toStatusId="LcPrvEntryCollected" transitionName="Collect Entry"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryPending" toStatusId="LcPrvEntryFailed" transitionName="Fail Entry"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryCollected" toStatusId="LcPrvEntryReleased" transitionName="Release Entry"/>
    <moqui.basic.StatusFlowTransition statusFlowId="LcProvisionCollectionEntry" statusId="LcPrvEntryFailed" toStatusId="LcPrvEntryPending" transitionName="Retry Entry"/>

    <!-- ========================================================= -->
    <!-- Role Types                                                -->
    <!-- ========================================================= -->
    <mantle.party.RoleType roleTypeId="Bank" description="Bank"/>

    <!-- Request Types -->
    <moqui.basic.Enumeration enumId="RqtLcIssuance" enumTypeId="RequestType" description="LC Issuance Request"/>
    <moqui.basic.Enumeration enumId="RqtLcAmendment" enumTypeId="RequestType" description="LC Amendment Request"/>

    <!-- ========================================================= -->
    <!-- Enumerations - SWIFT MT700 Field Codes                    -->
    <!-- ========================================================= -->

    <!-- 40A: Form of Documentary Credit -->
    <moqui.basic.EnumerationType enumTypeId="LcFormOfCredit" description="LC Form of Credit"/>
    <moqui.basic.Enumeration enumId="LC_FORM_IRREVOCABLE" enumTypeId="LcFormOfCredit" description="Irrevocable"/>
    <moqui.basic.Enumeration enumId="LC_FORM_REVOCABLE" enumTypeId="LcFormOfCredit" description="Revocable"/>
    <moqui.basic.Enumeration enumId="LC_FORM_IRREV_TRANS" enumTypeId="LcFormOfCredit" description="Irrevocable Transferable"/>

    <!-- 40E: Applicable Rules -->
    <moqui.basic.EnumerationType enumTypeId="LcApplicableRules" description="LC Applicable Rules"/>
    <moqui.basic.Enumeration enumId="LC_RULE_UCP_LATEST" enumTypeId="LcApplicableRules" description="UCP Latest Version"/>
    <moqui.basic.Enumeration enumId="LC_RULE_UCP600" enumTypeId="LcApplicableRules" description="UCP600"/>
    <moqui.basic.Enumeration enumId="LC_RULE_EUCP_LATEST" enumTypeId="LcApplicableRules" description="eUCP Latest Version"/>

    <!-- 41A: Available With... By... -->
    <moqui.basic.EnumerationType enumTypeId="LcAvailability" description="LC Availability Method"/>
    <moqui.basic.Enumeration enumId="LC_AVAIL_PAYMENT" enumTypeId="LcAvailability" description="By Payment"/>
    <moqui.basic.Enumeration enumId="LC_AVAIL_ACCEPTANCE" enumTypeId="LcAvailability" description="By Acceptance"/>
    <moqui.basic.Enumeration enumId="LC_AVAIL_NEGOTIATION" enumTypeId="LcAvailability" description="By Negotiation"/>
    <moqui.basic.Enumeration enumId="LC_AVAIL_DEFERRED" enumTypeId="LcAvailability" description="By Deferred Payment"/>

    <!-- 43P: Partial Shipments -->
    <moqui.basic.EnumerationType enumTypeId="LcPartialShipment" description="LC Partial Shipment"/>
    <moqui.basic.Enumeration enumId="LC_PARTIAL_ALLOWED" enumTypeId="LcPartialShipment" description="ALLOWED"/>
    <moqui.basic.Enumeration enumId="LC_PARTIAL_NOT_ALLOW" enumTypeId="LcPartialShipment" description="NOT ALLOWED"/>
    <moqui.basic.Enumeration enumId="LC_PARTIAL_COND" enumTypeId="LcPartialShipment" description="CONDITIONAL"/>

    <!-- 43T: Transhipment -->
    <moqui.basic.EnumerationType enumTypeId="LcTranshipment" description="LC Transhipment"/>
    <moqui.basic.Enumeration enumId="LC_TRANS_ALLOWED" enumTypeId="LcTranshipment" description="ALLOWED"/>
    <moqui.basic.Enumeration enumId="LC_TRANS_NOT_ALLOW" enumTypeId="LcTranshipment" description="NOT ALLOWED"/>
    <moqui.basic.Enumeration enumId="LC_TRANS_COND" enumTypeId="LcTranshipment" description="CONDITIONAL"/>

    <!-- 49: Confirmation Instructions -->
