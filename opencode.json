{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/mimo-v2-flash-free",
  "default_agent": "plan",
  "agent": {
    "build": {
      "description": "Primary development agent with full file access for TradeFinance component",
      "mode": "primary",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": "allow",
        "read": "allow"
      }
    },
    "plan": {
      "description": "Analysis and planning agent for TradeFinance architecture and design",
      "mode": "primary",
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "find *": "allow",
          "ls *": "allow",
          "rg *": "allow",
          "git status": "allow",
          "git diff": "allow",
          "git log*": "allow"
        }
      }
    },
    "trade-expert": {
      "description": "TradeFinance domain expert for business rules, processing, and regulations",
      "mode": "subagent",
      "model": "opencode/mimo-v2-flash-free",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "explore": {
      "description": "Fast code exploration and search agent",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  }
}
