<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd"
        default-menu-title="Drawing" default-menu-index="4">

    <parameter name="lcId" required="false"/>
    <parameter name="drawingId"/>

    <transition name="transitionDrawingStatus">
        <service-call name="moqui.trade.finance.DrawingServices.transition#DrawingStatus"/>
        <default-response url="."/></transition>
    <transition name="ExamineDocs"><service-call name="moqui.trade.finance.DrawingServices.examine#LcDrawing"/><default-response url="."/></transition>

    <actions>
        <if condition="lcId">
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
        </if>
        <if condition="drawingId">
            <entity-find-one entity-name="moqui.trade.finance.LcDrawing" value-field="drawing">
                <field-map field-name="lcId" from="lcId"/>
                <field-map field-name="drawingSeqId" from="drawingId"/>
            </entity-find-one>
            <if condition="drawing">
                <set field="statusColorMap" from="['LcDrReceived':'grey-7', 'LcDrCompliant':'blue-8', 'LcDrDiscrepant':'orange-8', 'LcDrAccepted':'green-8', 'LcDrUnderTrust':'indigo-8', 'LcDrPaid':'teal-8', 'LcDrRejected':'red-8']"/>

                <entity-find-one entity-name="moqui.basic.StatusItem" value-field="drStatus" is-pk="true">
                    <field-map field-name="statusId" from="drawing.drawingStatusId"/></entity-find-one>
                <set field="drStatusDesc" from="drStatus?.description ?: (drawing.drawingStatusId ?: 'N/A')"/>
                <set field="drStatusColor" from="statusColorMap[drawing.drawingStatusId] ?: 'grey-7'"/>

                <!-- Fetch valid Drawing Transitions -->
                <entity-find entity-name="moqui.basic.StatusFlowTransition" list="stList">
                    <econdition field-name="statusFlowId" value="LcDrawingStatus"/>
                    <econdition field-name="statusId" from="drawing.drawingStatusId"/>
                </entity-find>
            </if>
        </if>
    </actions>

    <subscreens default-item="FindDrawing">
        <subscreens-item name="FindDrawing" location="component://TradeFinance/screen/TradeFinance/ImportLc/Drawing/FindDrawing.xml" menu-include="false"/>
        <subscreens-item name="DrawingDetail" menu-title="Examination" location="component://TradeFinance/screen/TradeFinance/ImportLc/Drawing/DrawingDetail.xml" menu-index="1"/>
    </subscreens>

    <widgets>
        <section name="DrawingDetailHeader" condition="drawingId &amp;&amp; !['FindDrawing'].contains(sri.screenUrlInfo.targetScreen?.getScreenName())">
            <widgets>
                <container style="q-pa-md pb-none">
                    <container style="row justify-between items-center q-mb-md">
                        <container>
                            <label text="Letter of Credit Drawing" type="h4" style="text-primary text-weight-bold q-mb-xs"/>
                            <container style="row items-center q-gutter-sm">
                                <label text="LC: ${lc?.lcNumber} | Drawing: ${drawingId}" style="text-subtitle2 text-grey-7"/>
                                <label text="${drStatusDesc}" style="q-chip bg-${drStatusColor} text-white shadow-1 text-weight-bold q-px-sm"/>
                            </container>
                        </container>
                        <container style="q-gutter-sm row items-center">
                            <link url="ExamineDocs" text="Automated Exam" parameter-map="[lcId:lcId, drawingSeqId:drawingId]"
                                  style="q-btn bg-teal text-white" condition="drawing.drawingStatusId == 'LcDrReceived'"/>
                            <section-iterate name="DrawingTransitions" list="stList" entry="st">
                                <widgets>
                                    <link url="transitionDrawingStatus" text="${st.transitionName}" 
                                          parameter-map="[lcId:lcId, drawingSeqId:drawingId, toStatusId:st.toStatusId]"
                                          style="${st.toStatusId == 'LcDrRejected' ? 'q-btn-outline text-red' : 'q-btn bg-primary text-white'}"/>
                                </widgets>
                            </section-iterate>
                            <link url="." text="Back" parameter-map="[drawingId:null]" style="q-btn-flat text-grey-7 q-ml-md"/>
                        </container>
                    </container>
                </container>
            </widgets>
        </section>

        <section name="DrawingContentTabs" condition="drawingId &amp;&amp; drawing &amp;&amp; !['FindDrawing', 'Drawing'].contains(sri.screenUrlInfo.targetScreen?.getScreenName())">
            <widgets>
                <container style="q-pa-md pt-none">
                    <subscreens-panel id="DrawingDetailTabs" type="tab"/>
                </container>
            </widgets>
            <fail-widgets>
                <subscreens-panel id="DrawingMainPanel" type="popup"/>
            </fail-widgets>
        </section>
    </widgets>


</screen>
