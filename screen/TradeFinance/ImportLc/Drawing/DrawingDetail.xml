<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd">
    <parameter name="lcId" required="true"/>
    <parameter name="drawingId" required="true"/>
    <parameter name="readOnly" type="Boolean" default="false"/>
    
    <transition name="transitionDrawingStatus">
        <service-call name="moqui.trade.finance.DrawingServices.transition#DrawingStatus"/>
        <default-response url="."/></transition>
    <transition name="ExamineDocs"><service-call name="moqui.trade.finance.DrawingServices.examine#LcDrawing"/><default-response url="."/></transition>
    <transition name="ResolveDiscrepancy"><service-call name="moqui.trade.finance.DrawingServices.resolve#LcDiscrepancy"/><default-response url="."/></transition>
    
    <actions>
        <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
        <entity-find-one entity-name="moqui.trade.finance.LcDrawing" value-field="drawing">
            <field-map field-name="lcId" from="lcId"/>
            <field-map field-name="drawingSeqId" from="drawingId"/>
        </entity-find-one>
        
        <if condition="drawing">
            <set field="statusColorMap" from="[LcDrReceived:'blue-8', LcDrCompliant:'green-8', LcDrDiscrepant:'orange-9', LcDrAccepted:'teal-8', LcDrUnderTrust:'indigo-8', LcDrPaid:'green-9', LcDrRejected:'red-8']"/>
            <entity-find-one entity-name="moqui.basic.StatusItem" value-field="drStatus">
                <field-map field-name="statusId" from="drawing.drawingStatusId"/></entity-find-one>
            <set field="drStatusDesc" from="drStatus?.description ?: drawing.drawingStatusId"/>
            <set field="drStatusColor" from="statusColorMap[drawing.drawingStatusId] ?: 'grey-7'"/>

            <entity-find entity-name="moqui.trade.finance.LcDiscrepancy" list="discrepancyList">
                <field-map field-name="lcId" from="lcId"/>
                <field-map field-name="drawingSeqId" from="drawing.drawingSeqId"/>
            </entity-find>
            
            <entity-find entity-name="moqui.trade.finance.LcDrawingDocument" list="docList">
                <field-map field-name="lcId" from="lcId"/>
                <field-map field-name="drawingSeqId" from="drawing.drawingSeqId"/>
            </entity-find>

            <!-- Fetch valid Drawing Transitions -->
            <entity-find entity-name="moqui.basic.StatusFlowTransition" list="stList">
                <econdition field-name="statusFlowId" value="LcDrawingStatus"/>
                <econdition field-name="statusId" from="drawing.drawingStatusId"/>
            </entity-find>
        </if>
        <set field="isReadOnly" from="readOnly || drawing?.drawingStatusId in ['LcDrPaid', 'LcDrRejected']"/>
    </actions>
    
    <widgets>
        <section name="DrawingDetailHeader" condition="drawing">
            <widgets>
                <container style="row justify-between items-center q-pa-md bg-white shadow-1 q-mb-md border-radius-8">
                    <container>
                        <label text="DRAWING: ${drawingId}" type="h5" style="text-weight-bold text-primary q-mr-md"/>
                        <label text="FOR LC: ${lc?.lcNumber}" style="q-mr-lg text-grey-7"/>
                        <render-mode><text type="html"><![CDATA[
                            <q-chip outline color="${drStatusColor}" text-color="${drStatusColor}" icon="assignment_turned_in">
                                ${drStatusDesc}
                            </q-chip>
                        ]]></text></render-mode>
                    </container>
                    <container>
                        <section-iterate name="StatusTransitions" list="stList" entry="st">
                            <widgets>
                                <container-dialog id="TransitionDialog_${st_index}" button-text="${st.transitionName}" button-style="q-ml-sm q-btn--outline" button-color="primary">
                                    <form-single name="TransitionForm_${st_index}" transition="transitionDrawingStatus">
                                        <field name="lcId"><default-field><hidden/></default-field></field>
                                        <field name="drawingSeqId" from="drawingId"><default-field><hidden/></default-field></field>
                                        <field name="toStatusId" from="st.toStatusId"><default-field><hidden/></default-field></field>
                                        <field name="comments"><default-field title="Comments"><text-area rows="3"/></default-field></field>
                                        <field name="submitBtn"><default-field><submit text="Confirm Transition"/></default-field></field>
                                    </form-single>
                                </container-dialog>
                            </widgets>
                        </section-iterate>
                        <section name="AutoExamSection" condition="drawing.drawingStatusId == 'LcDrReceived'">
                            <widgets>
                                <link url="ExamineDocs" text="Automated Exam" parameter-map="[lcId:lcId, drawingSeqId:drawingId]" 
                                      style="q-ml-sm q-btn--push" transition="ExamineDocs" btn-type="success"/>
                            </widgets>
                        </section>
                    </container>
                </container>
            </widgets>
        </section>

        <section name="DrawingFoundSection" condition="drawing">
            <widgets>
                <container style="q-pa-md">
                    <label text="Drawing Detail" type="h4" style="text-primary text-weight-bold q-mb-md"/>
                    <container style="row q-col-gutter-md">
                        <!-- Left Column: Details -->
                        <container style="col-12 col-md-8">
                            <container style="q-card q-mb-md shadow-1">
                                <container style="q-pa-sm bg-blue-grey-1 text-weight-bold">DRAWING FINANCIALS</container>
                                <container style="q-pa-md">
                                    <form-single name="DrawingInfoForm" map="drawing">
                                        <field name="presentationDate"><default-field title="Presentation Date"><display/></default-field></field>
                                        <field name="drawingAmount"><default-field title="Drawing Amount">
                                            <display currency-uom-id="${drawing.drawingCurrencyUomId}"/>
                                        </default-field></field>
                                        <field name="maturityDate"><default-field title="Maturity Date"><display/></default-field></field>
                                        <field name="documentCount"><default-field title="Number of Documents"><display/></default-field></field>
                                        <field name="remarks"><default-field title="Remarks"><display/></default-field></field>
                                    </form-single>
                                </container>
                            </container>

                            <container style="q-card q-mb-md shadow-1">
                                <container style="q-pa-sm bg-blue-grey-1 text-weight-bold">PRESENTATION METRICS</container>
                                <container style="q-pa-md">
                                    <form-list name="DocList" list="docList" skip-form="true">
                                        <field name="documentTypeEnumId"><default-field title="Document Type">
                                            <display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/>
                                        </default-field></field>
                                        <field name="documentReference"><default-field title="Reference No."><display/></default-field></field>
                                        <field name="documentDate"><default-field title="Doc Date"><display/></default-field></field>
                                        <field name="originalCount"><default-field title="Originals"><display/></default-field></field>
                                        <field name="copyCount"><default-field title="Copies"><display/></default-field></field>
                                    </form-list>
                                </container>
                            </container>

                            <container style="q-card shadow-1">
                                <container style="q-pa-sm bg-orange-1 text-orange-10 text-weight-bold">DISCREPANCIES &amp; FINDINGS</container>
                                <container style="q-pa-md">
                                    <form-list name="DiscrepancyList" list="discrepancyList" skip-form="true">
                                        <field name="discrepancyTypeEnumId"><default-field title="Type">
                                            <display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/>
                                        </default-field></field>
                                        <field name="description"><default-field title="Observation"><display/></default-field></field>
                                        <field name="resolutionEnumId"><default-field title="Resolution">
                                            <display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/>
                                        </default-field></field>
                                        <field name="resolveBtn" condition="!resolutionEnumId">
                                            <default-field title="Action">
                                                <container-dialog id="ResolveDialog" button-text="Resolve" button-style="q-btn--flat" button-color="primary">
                                                    <form-single name="ResolveForm" transition="ResolveDiscrepancy">
                                                        <field name="lcId"><default-field><hidden/></default-field></field>
                                                        <field name="drawingSeqId" from="drawingId"><default-field><hidden/></default-field></field>
                                                        <field name="discrepancySeqId"><default-field><hidden/></default-field></field>
                                                        <field name="resolutionEnumId"><default-field title="Resolution">
                                                            <drop-down allow-empty="false">
                                                                <entity-options key="${enumId}" text="${description}">
                                                                    <entity-find entity-name="moqui.basic.Enumeration">
                                                                        <econdition field-name="enumTypeId" value="LcDiscrepancyResolution"/>
                                                                    </entity-find>
                                                                </entity-options>
                                                            </drop-down>
                                                        </default-field></field>
                                                        <field name="submit"><default-field><submit text="Resolve Discrepancy"/></default-field></field>
                                                    </form-single>
                                                </container-dialog>
                                            </default-field>
                                        </field>
                                    </form-list>
                                </container>
                            </container>
                        </container>

                        <!-- Right Column: Context &amp; History -->
                        <container style="col-12 col-md-4">
                            <container style="q-card q-mb-md shadow-1">
                                <container style="q-pa-sm bg-blue-grey-1 text-weight-bold">PAYMENT STATUS</container>
                                <container style="q-pa-md">
                                    <form-single name="PaymentForm" map="drawing">
                                        <field name="paymentDate"><default-field title="Paid On"><display/></default-field></field>
                                        <field name="paymentAmount"><default-field title="Paid Amount">
                                            <display currency-uom-id="${drawing.drawingCurrencyUomId}"/>
                                        </default-field></field>
                                        <field name="paymentReference"><default-field title="Payment Ref"><display/></default-field></field>
                                    </form-single>
                                </container>
                            </container>

                            <container style="q-card shadow-1">
                                <container style="q-pa-sm bg-blue-grey-1 text-weight-bold">LC PARTIES CONTEXT</container>
                                <container style="q-pa-md">
                                    <form-single name="LcPartiesForm" map="lc">
                                        <field name="applicantPartyId"><default-field title="Applicant">
                                            <display-entity entity-name="mantle.party.PartyDetailAndRole" text="${organizationName?:firstName+' '+lastName}"/>
                                        </default-field></field>
                                        <field name="beneficiaryPartyId"><default-field title="Beneficiary">
                                            <display-entity entity-name="mantle.party.PartyDetailAndRole" text="${organizationName?:firstName+' '+lastName}"/>
                                        </default-field></field>
                                        <field name="issuingBankPartyId"><default-field title="Issuing Bank">
                                            <display-entity entity-name="mantle.party.PartyDetailAndRole" text="${organizationName?:firstName+' '+lastName}"/>
                                        </default-field></field>
                                    </form-single>
                                </container>
                            </container>
                        </container>
                    </container>
                </container>
            </widgets>
            <fail-widgets>
                <container style="q-pa-md">
                    <label text="Drawing record not found." type="h5" style="text-negative"/>
                </container>
            </fail-widgets>
        </section>
    </widgets>
</screen>
