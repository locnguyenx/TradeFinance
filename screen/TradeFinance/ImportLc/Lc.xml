<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd"
        default-menu-title="Letter of Credit" default-menu-index="1">

    <!-- Clean Parent Pattern: don't explicitly declare parameters here
    <parameter name="lcId"/>
    -->

    <transition-include name="SubmitLc" location="component://TradeFinance/template/lc/LcTransitions.xml"/>
    <transition name="IssueLc">
        <service-call name="moqui.trade.finance.LifecycleServices.issue#LetterOfCredit"/>
        <default-response url="." parameter-map="[lcId:lcId]"/>
    </transition>
    <transition name="transitionLcStatus">
        <service-call name="update#moqui.trade.finance.LetterOfCredit"/>
        <default-response url="." parameter-map="[lcId:lcId]"/>
    </transition>

    <actions>
        <set field="lcId" from="lcId ?: lcSeqId"/>
        <if condition="lcId">
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
        </if>
        <if condition="lc">
            <set field="statusColorMap" from="['LcTxDraft':'grey-7', 'LcTxSubmitted':'blue-8', 'LcTxApproved':'green-8', 'LcTxRejected':'red-8']"/>
            <entity-find-one entity-name="moqui.basic.StatusItem" value-field="lcStatus" is-pk="true">
                <field-map field-name="statusId" from="lc.transactionStatusId"/></entity-find-one>
            <set field="lcStatusDesc" from="lcStatus?.description ?: (lc.transactionStatusId ?: 'N/A')"/>
            <set field="lcStatusColor" from="statusColorMap[lc.transactionStatusId] ?: 'grey-7'"/>

            <!-- Fetch valid LC Transitions (for the header buttons) -->
            <entity-find entity-name="moqui.basic.StatusFlowTransition" list="stList">
                <econdition field-name="statusFlowId" value="LcTransaction"/>
                <econdition field-name="statusId" from="lc.transactionStatusId"/>
            </entity-find>
        </if>
    </actions>

    <subscreens default-item="FindLc">
        <subscreens-item name="MainLC" menu-title="Letter of Credit Detail" location="component://TradeFinance/screen/TradeFinance/ImportLc/Lc/MainLC.xml"
                         parameter-map="[lcId:lcId]" menu-index="1"/>
        <subscreens-item name="FindLc" menu-title="Find LC" location="component://TradeFinance/screen/TradeFinance/ImportLc/Lc/FindLc.xml" menu-include="false"/>
        <subscreens-item name="Amendments" menu-title="Amendments" location="component://TradeFinance/screen/TradeFinance/ImportLc/Lc/Amendments.xml"
                         parameter-map="[lcId:lcId]" menu-index="2"/>
        <subscreens-item name="Drawings" menu-title="Drawings" location="component://TradeFinance/screen/TradeFinance/ImportLc/Lc/Drawings.xml"
                         parameter-map="[lcId:lcId]" menu-index="3"/>
        <subscreens-item name="Financials" menu-title="Financials" location="component://TradeFinance/screen/TradeFinance/ImportLc/Lc/Financials.xml"
                         parameter-map="[lcId:lcId]" menu-index="4"/>
        <subscreens-item name="History" menu-title="History" location="component://TradeFinance/screen/TradeFinance/ImportLc/Lc/History.xml"
                         parameter-map="[lcId:lcId]" menu-index="5"/>
    </subscreens>

    <widgets>
        <section name="LcDetailHeader" condition="lc">
            <widgets>
                <container style="q-pa-md pb-none">
                    <container style="row justify-between items-center q-mb-md">
                        <container>
                            <label text="Letter of Credit" type="h4" style="text-primary text-weight-bold q-mb-xs"/>
                            <container style="row items-center q-gutter-sm">
                                <label text="LC: ${lc?.lcNumber ?: 'N/A'} | ID: ${lcId}" style="text-subtitle2 text-grey-7"/>
                                <label text="${lcStatusDesc}" style="q-chip bg-${lcStatusColor} text-white shadow-1 text-weight-bold q-px-sm"/>
                            </container>
                        </container>
                        <container style="q-gutter-sm row items-center">
                            <!-- Status Transitions -->
                            <section-iterate name="LcTransitions" list="stList" entry="st">
                                <widgets>
                                    <!-- Map generic status transitions to specific services where needed -->
                                    <link url="${st.toStatusId == 'LcTxSubmitted' ? 'SubmitLc' : (st.toStatusId == 'LcTxApproved' ? 'IssueLc' : 'transitionLcStatus')}" 
                                          text="${st.transitionName}" 
                                          parameter-map="[lcId:lcId, toStatusId:st.toStatusId]"
                                          style="${st.toStatusId == 'LcTxRejected' ? 'q-btn-outline text-red' : 'q-btn bg-primary text-white'}"/>
                                </widgets>
                            </section-iterate>
                            
                            <link url="." text="Back" parameter-map="[lcId:null]" style="q-btn-flat text-grey-7 q-ml-md"/>
                        </container>
                    </container>
                </container>
            </widgets>
        </section>

        <section name="LcContentTabs" condition="lc">
            <widgets>
                <container style="q-pa-md pt-none">
                    <subscreens-panel id="LcTabs" type="tab"/>
                </container>
            </widgets>
            <fail-widgets>
                <subscreens-panel id="LcMainPanel" type="none"/>
            </fail-widgets>
        </section>
    </widgets>
</screen>
