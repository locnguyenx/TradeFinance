<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd">
    <parameter name="lcId" required="true"/>
    <parameter name="readOnly"/>
    <transition-include name="CreateAmendment" location="component://TradeFinance/template/lc/AmendmentTransitions.xml"/>
    
    <actions>
        <set field="isReadOnly" from="readOnly == 'true' || readOnly == true"/>
        <entity-find entity-name="moqui.trade.finance.LcAmendmentDetailView" list="amendmentList">
            <econdition field-name="lcId"/>
            <order-by field-name="-amendmentNumber"/>
        </entity-find>
    </actions>
    
    <widgets>
        <container style="q-pa-md">
            <container style="row justify-between items-center q-mb-md">
                <label text="LC Amendments" type="h5" style="text-primary text-weight-bold"/>
                <section name="CreateAmendmentSection" condition="!isReadOnly">
                    <widgets><include-screen name="CreateAmendment" location="component://TradeFinance/template/lc/CreateAmendment.xml"/></widgets>
                </section>
            </container>

            <form-list name="AmendmentList" list="amendmentList" skip-form="true" header-dialog="true">
                <field name="amendmentSeqId"><header-field show-order-by="true" title="Request ID"/><default-field>
                    <link url="../../Amendment/AmendmentDetail" text="${amendmentSeqId}" style="text-weight-bold text-primary" 
                          parameter-map="[lcId:lcId, amendmentSeqId:amendmentSeqId]"/>
                </default-field></field>

                <field name="amendmentNumber"><header-field show-order-by="true" title="Amnd #"/><default-field>
                    <display text="${amendmentNumber ?: 'Draft'}"/>
                </default-field></field>

                <field name="amendmentDate"><header-field show-order-by="true"/><default-field><display/></default-field></field>

                <field name="amendmentStatusId"><header-field title="Processing Status"/><default-field>
                    <display text="${statusDescription ?: amendmentStatusId}"/>
                </default-field></field>

                <field name="confirmationStatusId"><header-field title="Counterparty"/><default-field>
                    <display-entity entity-name="moqui.basic.StatusItem" key-field-name="statusId" text="${description}"/>
                </default-field></field>

                <field name="viewDetail"><default-field title="">
                    <link url="../../Amendment/AmendmentDetail" text="View Detail" link-type="anchor" parameter-map="[lcId:lcId, amendmentSeqId:amendmentSeqId]"/>
                </default-field></field>
            </form-list>
        </container>
    </widgets>
</screen>
