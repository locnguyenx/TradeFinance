<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd">
    <parameter name="lcId" required="true"/>
    
    <transition name="createLcCharge">
        <service-call name="moqui.trade.finance.TradeFinanceServices.create#LcCharge" in-map="context"/>
        <default-response url="."/>
    </transition>
    <transition name="updateLcCharge">
        <service-call name="moqui.trade.finance.TradeFinanceServices.update#LcCharge" in-map="context"/>
        <default-response url="."/>
    </transition>
    <transition name="deleteLcCharge">
        <service-call name="moqui.trade.finance.TradeFinanceServices.delete#LcCharge" in-map="context"/>
        <default-response url="."/>
    </transition>
    
    <!-- Provision Collection Transitions -->
    <transition name="createProvisionCollection">
        <service-call name="moqui.trade.finance.ProvisionCollectionServices.create#LcProvisionCollection" in-map="context"/>
        <default-response url="."/>
    </transition>
    <transition name="addCollectionEntry">
        <service-call name="moqui.trade.finance.ProvisionCollectionServices.add#CollectionEntry" in-map="context"/>
        <default-response url="."/>
    </transition>
    <transition name="validateCollection">
        <service-call name="moqui.trade.finance.ProvisionCollectionServices.validate#CollectionTotal" in-map="context"/>
        <actions>
            <script>
                if (isValid == true || isValid == "true") {
                    ec.message.addSuccess(message ?: "Collection is valid: ${collectedAmount} USD matches target ${targetAmount} USD")
                } else {
                    ec.message.addError(message ?: "Collection is invalid: ${collectedAmount} USD does not match target ${targetAmount} USD")
                }
            </script>
        </actions>
        <default-response url="."/>
    </transition>
    <transition name="collectProvisionFunds">
        <service-call name="moqui.trade.finance.ProvisionCollectionServices.collect#ProvisionFunds" in-map="context"/>
        <default-response url="."/>
    </transition>
    <transition name="releaseProvisionCollection">
        <service-call name="moqui.trade.finance.ProvisionCollectionServices.release#ProvisionCollection" in-map="context"/>
        <default-response url="."/>
    </transition>

    <actions>
        <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
        <entity-find entity-name="moqui.trade.finance.LcCharge" list="chargeList">
            <econdition field-name="lcId"/>
            <order-by field-name="-chargeDate"/>
        </entity-find>
        
        <!-- Provision Collection Data -->
        <entity-find entity-name="moqui.trade.finance.LcProvisionCollection" list="collectionList">
            <econdition field-name="lcId"/>
            <order-by field-name="-collectionDate"/>
        </entity-find>
        <set field="provisionCollection" from="collectionList ? collectionList.first() : null"/>
        <if condition="provisionCollection">
            <entity-find entity-name="moqui.trade.finance.LcProvisionCollectionEntry" list="collectionEntryList">
                <econdition field-name="collectionId" from="provisionCollection.collectionId"/>
            </entity-find>
            <!-- Set explicit context variables for form -->
            <set field="collectionId" from="provisionCollection.collectionId"/>
            <set field="partyId" from="lc?.applicantPartyId"/>
        </if>
        
        <!-- Get currency options -->
        <entity-find entity-name="moqui.basic.Uom" list="currencyList">
            <econdition field-name="uomTypeEnumId" value="UT_CURRENCY_MEASURE"/>
            <order-by field-name="uomId"/>
        </entity-find>
    </actions>
    
    <widgets>
        <container style="q-pa-md">
            <label text="Financials: Provision &amp; Charges" type="h5" style="text-primary text-weight-bold q-mb-md"/>
            
            <!-- Provision Collection Section (R8.12) -->
            <container style="q-card q-mb-lg shadow-1 border">
                <container style="q-pa-sm bg-green-1 text-green-10 text-weight-bold row justify-between items-center">
                    <label text="PROVISION COLLECTION"/>
                    <section name="CreateCollectionSection" condition="!provisionCollection">
                        <widgets>
                            <link url="createProvisionCollection" text="Collect Provision" parameter-map="[lcId:lcId, targetProvisionAmount:lc?.amount, targetCurrencyUomId:lc?.amountCurrencyUomId]"
                                  style="q-btn bg-green-8 text-white"/>
                        </widgets>
                    </section>
                </container>
                
                <container style="q-pa-md">
                    <section name="ProvisionCollectionDetails" condition="provisionCollection">
                        <widgets>
                            <!-- Collection Summary -->
                            <container style="row q-col-gutter-md q-mb-md">
                                <container style="col-12 col-md-4">
                                    <container style="q-pa-sm bg-grey-2 rounded-borders">
                                        <label text="Target Provision" style="text-grey-7"/>
                                        <label text="${provisionCollection.targetProvisionAmount ?: '0.00'} ${provisionCollection.targetCurrencyUomId ?: 'USD'}" type="h6" style="text-weight-bold"/>
                                    </container>
                                </container>
                                <container style="col-12 col-md-4">
                                    <container style="q-pa-sm bg-grey-2 rounded-borders">
                                        <label text="Collected" style="text-grey-7"/>
                                        <label text="${provisionCollection.collectedAmount ?: '0.00'} USD" type="h6" style="text-weight-bold"/>
                                    </container>
                                </container>
                                <container style="col-12 col-md-4">
                                    <container style="q-pa-sm rounded-borders ${provisionCollection.collectionStatusId == 'LcPrvColCollected' ? 'bg-green-2' : (provisionCollection.collectionStatusId == 'LcPrvColComplete' ? 'bg-yellow-2' : 'bg-grey-2')}">
                                        <label text="Status" style="text-grey-7"/>
                                        <label text="${provisionCollection.collectionStatusId == 'LcPrvColDraft' ? 'Draft' : (provisionCollection.collectionStatusId == 'LcPrvColComplete' ? 'Complete' : (provisionCollection.collectionStatusId == 'LcPrvColCollected' ? 'Collected' : (provisionCollection.collectionStatusId ?: 'Draft')))}" type="h6" style="text-weight-bold"/>
                                    </container>
                                </container>
                            </container>
                            
                            <!-- Collection Entries Table -->
                            <container style="q-mb-md">
                                <label text="Collection Entries" style="text-weight-bold q-mb-sm"/>
                                <form-list name="CollectionEntries" list="collectionEntryList" skip-form="true">
                                    <field name="accountId"><default-field title="Account"><display/></default-field></field>
                                    <field name="sourceCurrencyUomId"><default-field title="Currency"><display/></default-field></field>
                                    <field name="sourceAmount"><default-field title="Amount"><display/></default-field></field>
                                    <field name="exchangeRate"><default-field title="Rate"><display/></default-field></field>
                                    <field name="convertedAmount"><default-field title="USD"><display/></default-field></field>
                                    <field name="entryStatusId"><default-field title="Status">
                                        <display-entity entity-name="moqui.basic.StatusItem" key-field-name="statusId" text="${description}"/>
                                    </default-field></field>
                                </form-list>
                                
                                <!-- Add Entry Button -->
                                <section name="AddEntrySection">
                                    <condition>provisionCollection != null &amp;&amp; provisionCollection.collectionStatusId == 'LcPrvColDraft'</condition>
                                    <widgets>
                                        <container-dialog id="AddCollectionEntryDialog" button-text="Add Entry" type="outline-primary" style="q-mt-sm">
                                            <form-single name="AddCollectionEntryForm" transition="addCollectionEntry">
                                                <field name="lcId"><default-field><hidden/></default-field></field>
                                                <field name="collectionId"><default-field><hidden/></default-field></field>
                                                <field name="accountId"><default-field title="Account">
                                                    <drop-down allow-empty="false">
                                                        <entity-options key="${accountId}" text="${accountId} (${currencyUomId})">
                                                            <entity-find entity-name="moqui.trade.finance.CbsSimulatorState">
                                                                <order-by field-name="accountId"/>
                                                            </entity-find>
                                                        </entity-options>
                                                    </drop-down>
                                                </default-field></field>
                                                <field name="partyId"><default-field><hidden/></default-field></field>
                                                <field name="sourceAmount"><default-field title="Amount"><text-line size="15"/></default-field></field>
                                                <field name="sourceCurrencyUomId"><default-field title="Currency">
                                                    <drop-down allow-empty="false">
                                                        <entity-options key="${uomId}" text="${uomId}">
                                                            <entity-find entity-name="moqui.basic.Uom">
                                                                <econdition field-name="uomTypeEnumId" value="UT_CURRENCY_MEASURE"/>
                                                            </entity-find>
                                                        </entity-options>
                                                    </drop-down>
                                                </default-field></field>
                                                <field name="submitBtn"><default-field title="Add"><submit/></default-field></field>
                                            </form-single>
                                        </container-dialog>
                                    </widgets>
                                </section>
                            </container>
                            
                            <!-- Collection Actions -->
                            <container style="row q-gutter-sm">
                                <link url="validateCollection" text="Validate" parameter-map="[collectionId:provisionCollection.collectionId]"
                                      condition="provisionCollection.collectionStatusId == 'LcPrvColDraft'"
                                      style="q-btn bg-blue-7 text-white"/>
                                <link url="collectProvisionFunds" text="Collect Funds" parameter-map="[collectionId:provisionCollection.collectionId]"
                                      condition="provisionCollection.collectionStatusId == 'LcPrvColComplete'"
                                      style="q-btn bg-green-8 text-white"/>
                                <link url="releaseProvisionCollection" text="Release Funds" parameter-map="[collectionId:provisionCollection.collectionId]"
                                      condition="provisionCollection.collectionStatusId == 'LcPrvColCollected'"
                                      style="q-btn bg-orange-8 text-white"/>
                            </container>
                        </widgets>
                    </section>
                    
                    <section name="NoCollectionSection" condition="!provisionCollection">
                        <widgets>
                            <label text="No provision collection exists. Click 'Collect Provision' to create one." style="text-grey-7 italic"/>
                        </widgets>
                    </section>
                </container>
            </container>

            <container style="row q-col-gutter-md">
                <container style="col-12">
                    <container style="q-card shadow-1 border">
                        <container style="q-pa-sm bg-orange-1 text-orange-10 text-weight-bold row justify-between items-center">
                            <label text="CHARGES"/>
                            <section name="AddManualChargeSection" condition="lc?.transactionStatusId == 'LcTxDraft'">
                                <widgets>
                                    <container-dialog id="AddChargeDialog" button-text="Manual Charge" type="primary">
                                        <form-single name="AddChargeForm" transition="createLcCharge">
                                            <field name="lcId"><default-field><hidden/></default-field></field>
                                            <field name="chargeTypeEnumId"><default-field title="Charge Type">
                                                <drop-down allow-empty="false">
                                                    <entity-options key="${enumId}" text="${description}">
                                                        <entity-find entity-name="moqui.basic.Enumeration">
                                                            <econdition field-name="enumTypeId" value="LcChargeType"/>
                                                        </entity-find>
                                                    </entity-options>
                                                </drop-down>
                                            </default-field></field>
                                            <field name="chargeAmount"><default-field title="Amount"><text-line size="10"/></default-field></field>
                                            <field name="chargeCurrencyUomId"><default-field title="Currency">
                                                <drop-down allow-empty="false"><entity-options key="${uomId}" text="${uomId} - ${description}">
                                                    <entity-find entity-name="moqui.basic.Uom"><econdition field-name="uomTypeEnumId" value="UT_CURRENCY_MEASURE"/></entity-find>
                                                </entity-options></drop-down>
                                            </default-field></field>
                                            <field name="remarks"><default-field title="Remarks"><text-area rows="2"/></default-field></field>
                                            <field name="submitBtn"><default-field title="Add"><submit/></default-field></field>
                                        </form-single>
                                    </container-dialog>
                                </widgets>
                            </section>
                        </container>
                        <container style="q-pa-md">
                            <form-list name="ChargeList" list="chargeList" transition="updateLcCharge">
                                <field name="lcId"><default-field><hidden/></default-field></field>
                                <field name="chargeSeqId"><default-field><hidden/></default-field></field>
                                <field name="chargeTypeEnumId"><default-field title="Type">
                                    <display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/>
                                </default-field></field>
                                <field name="chargeAmount"><default-field title="Amount">
                                    <text-line size="8" condition="lc?.transactionStatusId == 'LcTxDraft'"/>
                                    <display condition="lc?.transactionStatusId != 'LcTxDraft'"/>
                                </default-field></field>
                                <field name="chargeDate"><default-field title="Date"><display/></default-field></field>
                                <field name="submitBtn"><default-field title="Update">
                                    <submit condition="lc?.transactionStatusId == 'LcTxDraft'"/>
                                </default-field></field>
                                <field name="deleteBtn"><default-field title=" ">
                                    <link url="deleteLcCharge" icon="fa fa-trash" confirmation="Delete this charge?" 
                                          condition="lc?.transactionStatusId == 'LcTxDraft'" 
                                          parameter-map="[lcId:lcId, chargeSeqId:chargeSeqId]"/>
                                </default-field></field>
                            </form-list>
                        </container>
                    </container>
                </container>
            </container>

            <!-- Security &amp; Collateral Summary (UC8.3.3) -->
            <container style="q-card q-mt-lg shadow-1 border">
                <container style="q-pa-sm bg-blue-grey-1 text-blue-grey-10 text-weight-bold">SECURITY &amp; COLLATERAL SUMMARY</container>
                <container style="q-pa-md">
                    <form-single name="SecuritySummary" map="lc">
                        <field name="isSecured"><default-field title="Is Secured?"><display/></default-field></field>
                        <field name="securedPercentage"><default-field title="Secured %"><display/></default-field></field>
                        <field name="collateralDescription"><default-field title="Collateral Description"><display/></default-field></field>
                        <field-layout>
                            <container style="row q-col-gutter-sm">
                                <container style="col-12 col-md-4"><field-ref name="isSecured"/></container>
                                <container style="col-12 col-md-4"><field-ref name="securedPercentage"/></container>
                            </container>
                            <field-ref name="collateralDescription"/>
                        </field-layout>
                    </form-single>
                </container>
            </container>

            <!-- Accounting Section (UC8.7.2) -->
            <container style="q-card q-mt-lg shadow-1 border">
                <container style="q-pa-sm bg-grey-8 text-white text-weight-bold">CBS ACCOUNTING ENTRIES</container>
                <container style="q-pa-md">
                    <label text="Visibility into ledger entries (Liability, Provisions, Payments) posted to CBS." style="italic text-grey-7"/>
                    <!-- Placeholder for dynamic accounting data in Phase 4.C -->
                </container>
            </container>
        </container>
    </widgets>
</screen>
