<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd"
        default-menu-include="false" default-menu-title="Find Import LC" default-menu-index="2">
    
    <transition name="LcDetail"><default-response url="../MainLC"/></transition>
    <transition-include name="CreateLc" location="component://TradeFinance/template/lc/LcTransitions.xml"/>
    <transition name="DeleteLc"><service-call name="moqui.trade.finance.TradeFinanceServices.delete#LetterOfCredit"/><default-response url="."/></transition>

    <actions>
        <entity-find entity-name="moqui.trade.finance.LetterOfCredit" list="lcList">
            <search-form-inputs/>
            <order-by field-name="-lcId"/>
        </entity-find>
    </actions>

    <widgets>
        <container style="q-pa-md">
            <container style="row justify-between items-center q-mb-md">
                <label text="Import Letters of Credit" type="h5" style="text-weight-bold text-primary"/>
                <include-screen location="component://TradeFinance/template/lc/CreateLc.xml"/>
            </container>

            <form-list name="LcList" list="lcList" skip-form="true" header-dialog="true">
                <field name="lcNumber"><header-field show-order-by="true" title="Reference #"/><default-field>
                    <link url="../MainLC" text="${lcNumber}" style="text-weight-bold text-primary" parameter-map="[lcId:lcId]"/>
                </default-field></field>
                <field name="applicantPartyId"><header-field show-order-by="true" title="Applicant"/><default-field>
                    <display-entity entity-name="mantle.party.PartyDetail" key-field-name="partyId" text="${organizationName}"/>
                </default-field></field>
                <field name="amount"><header-field show-order-by="true"/><default-field>
                    <display currency-uom-id="${amountCurrencyUomId}"/>
                </default-field></field>
                <field name="lcStatusId"><header-field title="LC Status"/><default-field>
                    <display-entity entity-name="moqui.basic.StatusItem" key-field-name="statusId" text="${description}"/>
                </default-field></field>
                <field name="transactionStatusId"><header-field title="Processing"/><default-field>
                    <display-entity entity-name="moqui.basic.StatusItem" key-field-name="statusId" text="${description}"/>
                </default-field></field>
                <field name="actions"><default-field title="">
                    <link url="DeleteLc" text="Delete" style="text-negative" parameter-map="[lcId:lcId]" confirmation="Confirm deletion?"/>
                </default-field></field>
            </form-list>
        </container>
    </widgets>
</screen>
