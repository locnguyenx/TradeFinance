<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.0.xsd">
    <parameter name="lcId" required="true"/>
    <parameter name="readOnly"/>
    <transition-include name="SubmitLc" location="component://TradeFinance/template/lc/LcTransitions.xml"/>
    <transition name="UpdateLc" condition="!isReadOnly">
        <service-call name="moqui.trade.finance.TradeFinanceServices.update#LetterOfCredit"/>
        <default-response url="." parameter-map="[lcId:lcId]"/>
    </transition>
    <transition name="IssueLc" condition="!isReadOnly">
        <service-call name="moqui.trade.finance.LifecycleServices.issue#LetterOfCredit"/>
        <default-response url="." parameter-map="[lcId:lcId]"/>
    </transition>
    
    <actions>
        <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
        <if condition="lc">
        </if>
        <set field="isReadOnly" from="readOnly == 'true' || readOnly == true"/>
        <log message="isReadOnly = ${isReadOnly}"/>
    </actions>
    
    <widgets>
        <section name="LcFoundSection" condition="lc">
            <widgets>
                <container style="q-pa-md">
                    <label text="Letter of Credit Detail" type="h4" style="text-primary text-weight-bold q-mb-md"/>
                    <form-single name="LcGeneralForm" map="lc" transition="UpdateLc" reload-save="true">
                        <auto-parameters entity-name="moqui.trade.finance.LetterOfCredit" include="pk"/>
                        <field name="lcId"><default-field><hidden/></default-field></field>

                        <!-- Removed redundant buttons: now in Lc.xml header -->
                        
                        <!-- 1. Reference &amp; Basic Info -->
                        <field name="lcNumber">
                            <conditional-field condition="isReadOnly" title="LC Number (20)"><display/></conditional-field>
                            <default-field title="LC Number (20)"><text-line size="20"/></default-field>
                        </field>
                        <field name="sequenceTotal_27">
                            <conditional-field condition="isReadOnly" title="Seq of Total (27)"><display/></conditional-field>
                            <default-field title="Seq of Total (27)"><text-line size="10" default-value="1/1"/></default-field>
                        </field>
                        <field name="cbsReference">
                            <default-field title="CBS Ref"><display/></default-field>
                        </field>
                        <field name="productId">
                            <conditional-field condition="isReadOnly" title="LC Product">
                                <display-entity entity-name="moqui.trade.finance.LcProduct" key-field-name="productId" text="${productName}"/>
                            </conditional-field>
                            <default-field title="LC Product">
                                <drop-down allow-empty="false">
                                    <entity-options key="${productId}" text="${productName}">
                                        <entity-find entity-name="moqui.trade.finance.LcProduct">
                                            <order-by field-name="productName"/>
                                        </entity-find>
                                    </entity-options>
                                </drop-down>
                            </default-field>
                        </field>
                        <field name="lcProductTypeEnumId">
                            <default-field title="Product Type (Enum)"><display-entity entity-name="moqui.basic.Enumeration"/></default-field>
                        </field>
                        <field name="formOfCredit_40A">
                            <conditional-field condition="isReadOnly" title="Form of Credit (40A)"><display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/></conditional-field>
                            <default-field title="Form of Credit (40A)">
                                <drop-down allow-empty="false"><entity-options key="${enumId}" text="${description}">
                                    <entity-find entity-name="moqui.basic.Enumeration"><econdition field-name="enumTypeId" value="LcFormOfCredit"/><order-by field-name="description"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="applicableRules_40E">
                            <conditional-field condition="isReadOnly" title="Applicable Rules (40E)"><display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/></conditional-field>
                            <default-field title="Applicable Rules (40E)">
                                <drop-down allow-empty="false"><entity-options key="${enumId}" text="${description}">
                                    <entity-find entity-name="moqui.basic.Enumeration"><econdition field-name="enumTypeId" value="LcApplicableRules"/><order-by field-name="description"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="issueDate">
                            <conditional-field condition="isReadOnly" title="Date of Issue (31C)"><display/></conditional-field>
                            <default-field title="Date of Issue (31C)"><date-time type="date"/></default-field>
                        </field>
                        <field name="expiryDate">
                            <conditional-field condition="isReadOnly" title="Date of Expiry (31D)"><display/></conditional-field>
                            <default-field title="Date of Expiry (31D)"><date-time type="date"/></default-field>
                        </field>
                        <field name="expiryPlace_31D">
                            <conditional-field condition="isReadOnly" title="Place of Expiry (31D)"><display/></conditional-field>
                            <default-field title="Place of Expiry (31D)"><text-line size="30"/></default-field>
                        </field>

                        <!-- 2. Amount &amp; Tolerance -->
                        <field name="amount">
                            <conditional-field condition="isReadOnly" title="LC Amount (32B)"><display/></conditional-field>
                            <default-field title="LC Amount (32B)"><text-line size="15"/></default-field>
                        </field>
                        <field name="amountCurrencyUomId">
                            <conditional-field condition="isReadOnly" title="Currency"><display-entity entity-name="moqui.basic.Uom" key-field-name="uomId" text="${description} (${abbreviation})"/></conditional-field>
                            <default-field title="Currency">
                                <drop-down allow-empty="false">
                                    <entity-options key="${uomId}" text="${description} (${abbreviation})">
                                        <entity-find entity-name="moqui.basic.Uom">
                                            <econdition field-name="uomTypeEnumId" value="UT_CURRENCY_MEASURE"/>
                                            <order-by field-name="description"/>
                                        </entity-find>
                                    </entity-options>
                                </drop-down>
                            </default-field>
                        </field>
                        <field name="amountTolerance_39A">
                            <conditional-field condition="isReadOnly" title="Tolerance % (39A)"><display/></conditional-field>
                            <default-field title="Tolerance % (39A)"><text-line size="10" placeholder="10/10"/></default-field>
                        </field>
                        <field name="maxCreditAmount_39B">
                            <conditional-field condition="isReadOnly" title="Max Credit Amt (39B)"><display/></conditional-field>
                            <default-field title="Max Credit Amt (39B)"><text-line size="20"/></default-field>
                        </field>
                        <field name="additionalAmountsCovered_39C">
                            <conditional-field condition="isReadOnly" title="Addl Amounts (39C)"><display/></conditional-field>
                            <default-field title="Addl Amounts (39C)"><text-area rows="2"/></default-field>
                        </field>

                        <!-- 3. Parties -->
                        <field name="applicantPartyId">
                            <conditional-field condition="isReadOnly" title="Applicant (50)"><display-entity entity-name="mantle.party.PartyDetail" key-field-name="partyId" text="${organizationName}"/></conditional-field>
                            <default-field title="Applicant (50)">
                                <drop-down allow-empty="true"><entity-options key="${partyId}" text="${organizationName}">
                                    <entity-find entity-name="mantle.party.PartyDetailAndRole"><econdition field-name="roleTypeId" value="Customer"/><order-by field-name="organizationName"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="beneficiaryPartyId">
                            <conditional-field condition="isReadOnly" title="Beneficiary (59)"><display-entity entity-name="mantle.party.PartyDetail" key-field-name="partyId" text="${organizationName}"/></conditional-field>
                            <default-field title="Beneficiary (59)">
                                <drop-down allow-empty="true"><entity-options key="${partyId}" text="${organizationName}">
                                    <entity-find entity-name="mantle.party.PartyDetailAndRole"><econdition field-name="roleTypeId" value="Vendor"/><order-by field-name="organizationName"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="issuingBankPartyId">
                            <conditional-field condition="isReadOnly" title="Issuing Bank (51A)"><display-entity entity-name="mantle.party.PartyDetail" key-field-name="partyId" text="${organizationName}"/></conditional-field>
                            <default-field title="Issuing Bank (51A)">
                                <drop-down allow-empty="true"><entity-options key="${partyId}" text="${organizationName}">
                                    <entity-find entity-name="mantle.party.PartyDetailAndRole"><econdition field-name="roleTypeId" value="Bank"/><order-by field-name="organizationName"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="advisingBankPartyId">
                            <conditional-field condition="isReadOnly" title="Advising Bank (57A)"><display-entity entity-name="mantle.party.PartyDetail" key-field-name="partyId" text="${organizationName}"/></conditional-field>
                            <default-field title="Advising Bank (57A)">
                                <drop-down allow-empty="true"><entity-options key="${partyId}" text="${organizationName}">
                                    <entity-find entity-name="mantle.party.PartyDetailAndRole"><econdition field-name="roleTypeId" value="Bank"/><order-by field-name="organizationName"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="reimbursingBankPartyId">
                            <conditional-field condition="isReadOnly" title="Reimbursing Bank (53A)"><display-entity entity-name="mantle.party.PartyDetail" key-field-name="partyId" text="${organizationName}"/></conditional-field>
                            <default-field title="Reimbursing Bank (53A)">
                                <drop-down allow-empty="true"><entity-options key="${partyId}" text="${organizationName}">
                                    <entity-find entity-name="mantle.party.PartyDetailAndRole"><econdition field-name="roleTypeId" value="Bank"/><order-by field-name="organizationName"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="advisingThroughBankPartyId">
                            <conditional-field condition="isReadOnly" title="Advise Through Bank (57A)"><display-entity entity-name="mantle.party.PartyDetail" key-field-name="partyId" text="${organizationName}"/></conditional-field>
                            <default-field title="Advise Through Bank (57A)">
                                <drop-down allow-empty="true"><entity-options key="${partyId}" text="${organizationName}">
                                    <entity-find entity-name="mantle.party.PartyDetailAndRole"><econdition field-name="roleTypeId" value="Bank"/><order-by field-name="organizationName"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="requestedConfirmationParty_58a">
                            <conditional-field condition="isReadOnly" title="Requested Confirmation Party (58a)"><display/></conditional-field>
                            <default-field title="Requested Confirmation Party (58a)"><text-line size="30"/></default-field>
                        </field>
                        <field name="advisingThroughBank_57a">
                            <conditional-field condition="isReadOnly" title="Advise Through Bank Name (57a)"><display/></conditional-field>
                            <default-field title="Advise Through Bank Name (57a)"><text-line size="30"/></default-field>
                        </field>
                        <field name="reimbursingBank_53a">
                            <conditional-field condition="isReadOnly" title="Reimbursing Bank Name (53a)"><display/></conditional-field>
                            <default-field title="Reimbursing Bank Name (53a)"><text-line size="30"/></default-field>
                        </field>

                        <!-- 4. Shipment Details -->
                        <field name="partialShipment_43P">
                            <conditional-field condition="isReadOnly" title="Partial Ship (43P)"><display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/></conditional-field>
                            <default-field title="Partial Ship (43P)">
                                <drop-down allow-empty="true"><entity-options key="${enumId}" text="${description}">
                                    <entity-find entity-name="moqui.basic.Enumeration"><econdition field-name="enumTypeId" value="LcPartialShipment"/><order-by field-name="description"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="transhipment_43T">
                            <conditional-field condition="isReadOnly" title="Transhipment (43T)"><display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/></conditional-field>
                            <default-field title="Transhipment (43T)">
                                <drop-down allow-empty="true"><entity-options key="${enumId}" text="${description}">
                                    <entity-find entity-name="moqui.basic.Enumeration"><econdition field-name="enumTypeId" value="LcTranshipment"/><order-by field-name="description"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="latestShipDate_44C">
                            <conditional-field condition="isReadOnly" title="Latest Ship Date (44C)"><display/></conditional-field>
                            <default-field title="Latest Ship Date (44C)"><date-time type="date"/></default-field>
                        </field>
                        <field name="placeOfReceipt_44A">
                            <conditional-field condition="isReadOnly" title="Place of Receipt (44A)"><display/></conditional-field>
                            <default-field title="Place of Receipt (44A)"><text-line size="30"/></default-field>
                        </field>
                        <field name="portOfLoading_44E">
                            <conditional-field condition="isReadOnly" title="Port of Loading (44E)"><display/></conditional-field>
                            <default-field title="Port of Loading (44E)"><text-line size="30"/></default-field>
                        </field>
                        <field name="portOfDischarge_44F">
                            <conditional-field condition="isReadOnly" title="Port of Discharge (44F)"><display/></conditional-field>
                            <default-field title="Port of Discharge (44F)"><text-line size="30"/></default-field>
                        </field>
                        <field name="placeOfFinalDestination_44B">
                            <conditional-field condition="isReadOnly" title="Final Destination (44B)"><display/></conditional-field>
                            <default-field title="Final Destination (44B)"><text-line size="30"/></default-field>
                        </field>
                        <field name="shipmentPeriod_44D">
                            <conditional-field condition="isReadOnly" title="Shipment Period (44D)"><display/></conditional-field>
                            <default-field title="Shipment Period (44D)"><text-area rows="2"/></default-field>
                        </field>

                        <!-- 5. Goods &amp; Documents -->
                        <field name="descriptionOfGoods_45A">
                            <conditional-field condition="isReadOnly" title="Goods (45A)"><display/></conditional-field>
                            <default-field title="Goods (45A)"><text-area rows="5"/></default-field>
                        </field>
                        <field name="docsRequired_46A">
                            <conditional-field condition="isReadOnly" title="Docs Required (46A)"><display/></conditional-field>
                            <default-field title="Docs Required (46A)"><text-area rows="5"/></default-field>
                        </field>
                        <field name="additionalConditions_47A">
                            <conditional-field condition="isReadOnly" title="Addl Conditions (47A)"><display/></conditional-field>
                            <default-field title="Addl Conditions (47A)"><text-area rows="5"/></default-field>
                        </field>

                        <!-- 6. Payment &amp; Instructions -->
                        <field name="availableWithBy_41A">
                            <conditional-field condition="isReadOnly" title="Available With/By (41A)"><display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/></conditional-field>
                            <default-field title="Available With/By (41A)">
                                <drop-down allow-empty="true"><entity-options key="${enumId}" text="${description}">
                                    <entity-find entity-name="moqui.basic.Enumeration"><econdition field-name="enumTypeId" value="LcAvailability"/><order-by field-name="description"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="draftsAt_42C">
                            <conditional-field condition="isReadOnly" title="Drafts At (42C)"><display/></conditional-field>
                            <default-field title="Drafts At (42C)"><text-line size="30"/></default-field>
                        </field>
                        <field name="periodForPresentation_48">
                            <conditional-field condition="isReadOnly" title="Presentation Period (48)"><display/></conditional-field>
                            <default-field title="Presentation Period (48)"><text-line size="20"/></default-field>
                        </field>
                        <field name="confirmationInstructions_49">
                            <conditional-field condition="isReadOnly" title="Confirmation (49)"><display-entity entity-name="moqui.basic.Enumeration" key-field-name="enumId" text="${description}"/></conditional-field>
                            <default-field title="Confirmation (49)">
                                <drop-down allow-empty="true"><entity-options key="${enumId}" text="${description}">
                                    <entity-find entity-name="moqui.basic.Enumeration"><econdition field-name="enumTypeId" value="LcConfirmation"/><order-by field-name="description"/></entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>
                        <field name="instructionsToBank_78">
                            <conditional-field condition="isReadOnly" title="Bank Instructions (78)"><display/></conditional-field>
                            <default-field title="Bank Instructions (78)"><text-area rows="3"/></default-field>
                        </field>
                        <field name="charges_71B">
                            <conditional-field condition="isReadOnly" title="Charges Info (71B)"><display/></conditional-field>
                            <default-field title="Charges Info (71B)"><text-area rows="2"/></default-field>
                        </field>
                        <field name="senderToReceiverInfo_72Z">
                            <conditional-field condition="isReadOnly" title="Sender Info (72Z)"><display/></conditional-field>
                            <default-field title="Sender Info (72Z)"><text-area rows="2"/></default-field>
                        </field>

                        <!-- Credit &amp; Collateral -->
                        <field name="isSecured">
                            <conditional-field condition="isReadOnly" title="Is Secured?"><display/></conditional-field>
                            <default-field title="Is Secured?"><drop-down allow-empty="true">
                                <option key="Y" text="Yes"/><option key="N" text="No"/>
                            </drop-down></default-field>
                        </field>
                        <field name="securedPercentage">
                            <conditional-field condition="isReadOnly" title="Secured %"><display/></conditional-field>
                            <default-field title="Secured %"><text-line size="10"/></default-field>
                        </field>
                        <field name="collateralDescription">
                            <conditional-field condition="isReadOnly" title="Collateral Description"><display/></conditional-field>
                            <default-field title="Collateral Description"><text-area rows="2"/></default-field>
                        </field>

                        <field name="submitButton">
                            <conditional-field condition="isReadOnly"><ignored/></conditional-field>
                            <default-field title="Save"><submit/></default-field>
                        </field>
                        
                        <field-layout>
                            <!-- Buttons moved to header -->

                            <field-ref name="lcId"/>

                            
                            <container style="q-card q-mb-md shadow-1 border">
                                <container style="q-pa-sm bg-blue-grey-1 text-weight-bold">1. REFERENCE &amp; BASIC INFO</container>
                                <container style="q-pa-md">
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="lcNumber"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="cbsReference"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-4"><field-ref name="sequenceTotal_27"/></container>
                                        <container style="col-12 col-md-4"><field-ref name="issueDate"/></container>
                                        <container style="col-12 col-md-4"><field-ref name="expiryDate"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="productId"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="lcProductTypeEnumId"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="expiryPlace_31D"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="formOfCredit_40A"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-12"><field-ref name="applicableRules_40E"/></container>
                                    </container>
                                </container>
                            </container>

                            <container style="q-card q-mb-md shadow-1 border">
                                <container style="q-pa-sm bg-indigo-1 text-weight-bold">2. AMOUNT &amp; TOLERANCE</container>
                                <container style="q-pa-md">
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="amount"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="amountCurrencyUomId"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="amountTolerance_39A"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="maxCreditAmount_39B"/></container>
                                    </container>
                                    <field-ref name="additionalAmountsCovered_39C"/>
                                </container>
                            </container>

                            <container style="q-card q-mb-md shadow-1 border">
                                <container style="q-pa-sm bg-teal-1 text-weight-bold">3. PARTIES</container>
                                <container style="q-pa-md">
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="applicantPartyId"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="beneficiaryPartyId"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-4"><field-ref name="issuingBankPartyId"/></container>
                                        <container style="col-12 col-md-4"><field-ref name="advisingBankPartyId"/></container>
                                        <container style="col-12 col-md-4"><field-ref name="reimbursingBankPartyId"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="advisingThroughBankPartyId"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="requestedConfirmationParty_58a"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="advisingThroughBank_57a"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="reimbursingBank_53a"/></container>
                                    </container>
                                </container>
                            </container>

                            <container style="q-card q-mb-md shadow-1 border">
                                <container style="q-pa-sm bg-blue-grey-1 text-weight-bold">4. CREDIT &amp; COLLATERAL</container>
                                <container style="q-pa-md">
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="isSecured"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="securedPercentage"/></container>
                                    </container>
                                    <field-ref name="collateralDescription"/>
                                </container>
                            </container>

                            <container style="q-card q-mb-md shadow-1 border">
                                <container style="q-pa-sm bg-orange-1 text-weight-bold">5. SHIPMENT DETAILS</container>
                                <container style="q-pa-md">
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="partialShipment_43P"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="transhipment_43T"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="latestShipDate_44C"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="placeOfReceipt_44A"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="portOfLoading_44E"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="portOfDischarge_44F"/></container>
                                    </container>
                                    <field-ref name="placeOfFinalDestination_44B"/>
                                    <field-ref name="shipmentPeriod_44D"/>
                                </container>
                            </container>

                            <container style="q-card q-mb-md shadow-1 border">
                                <container style="q-pa-sm bg-deep-orange-1 text-weight-bold">6. GOODS &amp; DOCUMENTS</container>
                                <container style="q-pa-md">
                                    <field-ref name="descriptionOfGoods_45A"/>
                                    <field-ref name="docsRequired_46A"/>
                                    <field-ref name="additionalConditions_47A"/>
                                </container>
                            </container>

                            <container style="q-card q-mb-md shadow-1 border">
                                <container style="q-pa-sm bg-blue-1 text-weight-bold">7. PAYMENT &amp; INSTRUCTIONS</container>
                                <container style="q-pa-md">
                                    <container style="row q-col-gutter-sm">
                                        <container style="col-12 col-md-6"><field-ref name="availableWithBy_41A"/></container>
                                        <container style="col-12 col-md-6"><field-ref name="confirmationInstructions_49"/></container>
                                    </container>
                                    <container style="row q-col-gutter-sm">
