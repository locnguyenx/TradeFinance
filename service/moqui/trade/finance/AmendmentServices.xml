<?xml version="1.0" encoding="UTF-8"?>
<!-- AmendmentServices.xml
     Services for managing LC amendments. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd"
          package="moqui.trade.finance">

    <!-- ========================================================= -->
    <!-- Create LC Amendment Service                               -->
    <!-- ========================================================= -->
    <service verb="create" noun="LcAmendment">
        <description>Creates a new amendment request (Draft) shadowing the current LC state.</description>
        <in-parameters>
            <auto-parameters entity-name="moqui.trade.finance.LcAmendment" include="nonpk"/>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentStatusId" default-value="LcTxDraft"/>
            <parameter name="remarks"/>
        </in-parameters>
        <out-parameters>
            <parameter name="amendmentSeqId"/>
            <parameter name="requestId"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="!lc"><return error="true" message="Letter of Credit not found."/></if>

            <!-- Validate LC is in Issued status for amendment -->
            <if condition="lc.lcStatusId != 'LcLfIssued'">
                <return error="true" message="Amendment cannot be created. LC must be in Issued status. Current status: ${lc.lcStatusId}"/>
            </if>

            <!-- Check for existing lock on this LC -->
            <entity-find-one entity-name="moqui.trade.finance.LcAmendmentLock" value-field="existingLock"/>
            <if condition="existingLock">
                <return error="true" message="LC is locked for amendment by ${existingLock.lockedByUserId}. Please try again later."/>
            </if>

            <!-- Check for existing pending amendment -->
            <entity-find entity-name="moqui.trade.finance.LcAmendment" list="existingAmendments">
                <econdition field-name="lcId"/>
                <econdition field-name="amendmentStatusId" value="LcTxDraft"/>
            </entity-find>
            <if condition="existingAmendments">
                <return error="true" message="A pending amendment already exists for this LC. Please complete or cancel the existing amendment first."/>
            </if>

            <!-- Create a Mantle Request for the amendment workflow -->
            <service-call name="create#mantle.request.Request" out-map="reqOut"
                in-map="[requestTypeEnumId:'RqtLcAmendment', statusId:'ReqDraft',
                         requestName:('LC Amendment: ' + lc.lcNumber),
                         description:('Amendment request for LC ' + lc.lcNumber)]"/>
            <set field="requestId" from="reqOut.requestId"/>

            <!-- Automated Shadow Copy: Copy all amendable fields from LC to Amendment -->
            <set field="amendmentMap" from="[:]"/>
            <script><![CDATA[
                def amendableFields = [
                    'productId', 'lcProductTypeEnumId', 'formOfCredit_40A', 'applicableRules_40E', 'expiryDate', 'expiryPlace_31D',
                    'amount', 'amountCurrencyUomId', 'amountTolerance_39A', 'maxCreditAmount_39B', 'additionalAmountsCovered_39C',
                    'beneficiaryPartyId', 'beneficiaryName', 'beneficiaryAddress', 'advisingBankPartyId', 'advisingBankName',
                    'advisingThroughBankPartyId', 'advisingThroughBank_57a', 'reimbursingBankPartyId', 'reimbursingBank_53a',
                    'requestedConfirmationParty_58a', 'partialShipment_43P', 'transhipment_43T', 'latestShipDate_44C',
                    'placeOfReceipt_44A', 'portOfLoading_44E', 'portOfDischarge_44F', 'placeOfFinalDestination_44B',
                    'descriptionOfGoods_45A', 'shipmentPeriod_44D', 'docsRequired_46A', 'additionalConditions_47A',
                    'instructionsToBank_78', 'periodForPresentation_48', 'charges_71B', 'senderToReceiverInfo_72Z',
                    'availableWithBy_41A', 'availableWithBankName', 'draftsAt_42C', 'confirmationInstructions_49',
                    'isSecured', 'securedPercentage', 'collateralDescription'
                ]
                
                if (context.fieldName) {
                    if (!amendableFields.contains(context.fieldName)) {
                        ec.message.addError("Field ${context.fieldName} cannot be amended.")
                    } else {
                        context.oldValue = lc[context.fieldName]
                    }
                }
                
                amendableFields.each { field -> 
                    amendmentMap[field] = (field == context.fieldName && context.newValue != null) ? context.newValue : lc[field] 
                }
            ]]></script>
            <check-errors/>

            <!-- Create the LcAmendment record with shadow data -->
            <service-call name="create#moqui.trade.finance.LcAmendment" 
                in-map="context + amendmentMap + [requestId:requestId, confirmationStatusId:'LcAmndPending']" out-map="newAmOut"/>
            <set field="amendmentSeqId" from="newAmOut.amendmentSeqId"/>

            <!-- R8.11: Automatically calculate charges for this amendment -->
            <service-call name="moqui.trade.finance.FinancialServices.calculate#LcCharges"
                          in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId]"/>

            <!-- Acquire amendment lock -->
            <service-call name="moqui.trade.finance.AmendmentServices.acquire#AmendmentLock" in-map="[lcId:lcId]"/>

            <log level="info" message="Created shadow LC Amendment Draft for LC: ${lcId}, Seq: ${amendmentSeqId}"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Submit LC Amendment Service                               -->
    <!-- ========================================================= -->
    <service verb="submit" noun="LcAmendment">
        <description>Submits the drafted LC amendment for review.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment"/>
            <if condition="!amendment"><return error="true" message="Amendment not found."/></if>
            
            <!-- Validate all mandatory fields are present -->
            <if condition="!amendment.amount"><return error="true" message="Amount is required for amendment submission."/></if>
            
            <service-call name="moqui.trade.finance.AmendmentServices.transition#AmendmentStatus"
                in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId, toStatusId:'LcTxSubmitted']"/>
            
            <!-- Release lock on submission -->
            <service-call name="moqui.trade.finance.AmendmentServices.release#AmendmentLock" in-map="[lcId:lcId]"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Approve LC Amendment Service                              -->
    <!-- ========================================================= -->
    <service verb="approve" noun="LcAmendment">
        <description>Approves the LC amendment internally.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
        </in-parameters>
        <actions>
            <service-call name="moqui.trade.finance.AmendmentServices.transition#AmendmentStatus"
                in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId, toStatusId:'LcTxApproved']"/>
        </actions>
    </service>
    <service verb="confirm" noun="LcAmendment">
        <description>Confirms the amendment and applies ALL shadow fields back to the master LC.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
            <parameter name="isAccepted" type="Boolean" default="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment" for-update="true"/>
            <if condition="!amendment"><return error="true" message="Amendment not found."/></if>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc" for-update="true"/>

            <if condition="isAccepted">
                <!-- Automated Apply: Copy all shadow fields from Amendment back to LC -->
                <script>
                    def amendableFields = [
                        'productId', 'lcProductTypeEnumId', 'formOfCredit_40A', 'applicableRules_40E', 'expiryDate', 'expiryPlace_31D',
                        'amount', 'amountCurrencyUomId', 'amountTolerance_39A', 'maxCreditAmount_39B', 'additionalAmountsCovered_39C',
                        'beneficiaryPartyId', 'beneficiaryName', 'beneficiaryAddress', 'advisingBankPartyId', 'advisingBankName',
                        'advisingThroughBankPartyId', 'advisingThroughBank_57a', 'reimbursingBankPartyId', 'reimbursingBank_53a',
                        'requestedConfirmationParty_58a', 'partialShipment_43P', 'transhipment_43T', 'latestShipDate_44C',
                        'placeOfReceipt_44A', 'portOfLoading_44E', 'portOfDischarge_44F', 'placeOfFinalDestination_44B',
                        'descriptionOfGoods_45A', 'shipmentPeriod_44D', 'docsRequired_46A', 'additionalConditions_47A',
                        'instructionsToBank_78', 'periodForPresentation_48', 'charges_71B', 'senderToReceiverInfo_72Z',
                        'availableWithBy_41A', 'availableWithBankName', 'draftsAt_42C', 'confirmationInstructions_49',
                        'isSecured', 'securedPercentage', 'collateralDescription'
                    ]
                    def updateMap = [:]
                    amendableFields.each { field -> if (amendment[field] != null) updateMap[field] = amendment[field] }
                    // Sync Enum if productId changed
                    if (updateMap.productId) {
                        def product = ec.entity.find("moqui.trade.finance.LcProduct").condition("productId", updateMap.productId).one()
                        if (product) updateMap.lcProductTypeEnumId = product.lcProductTypeEnumId
                    }
                    lc.setAll(updateMap)
                </script>
                
                <set field="lc.amendmentNumber" from="(lc.amendmentNumber ?: 0) + 1"/>
                <entity-update value-field="lc"/>

                <!-- Mark Amendment as Confirmed -->
                <set field="amendment.confirmationStatusId" value="LcAmndConfirmed"/>
                <set field="amendment.amendmentNumber" from="lc.amendmentNumber"/>
                <entity-update value-field="amendment"/>
                
                <service-call name="moqui.trade.finance.TradeFinanceServices.transition#LcStatus"
                    in-map="[lcId:lcId, toStatusId:'LcLfAmended', comments:('Amendment #' + lc.amendmentNumber + ' confirmed.')]"/>

                <!-- Mark Amendment as Closed -->
                <service-call name="moqui.trade.finance.AmendmentServices.transition#AmendmentStatus"
                    in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId, toStatusId:'LcTxClosed']"/>
                
                <!-- Refresh objects to avoid overwriting status changes with stale local objects -->
                <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
                <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment"/>

                <!-- Generate MT707 Amendment Advice -->
                <service-call name="moqui.trade.finance.SwiftServices.generate#SwiftMt707"
                    in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId]"/>

                <!-- Post Amendment Charges to GL -->
                <service-call name="moqui.trade.finance.AccountingServices.post#LcChargesToInvoice"
                    in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId]"/>
            <else>
                <set field="amendment.confirmationStatusId" value="LcAmndRej"/>
            </else></if>

            <set field="amendment.confirmationDate" from="ec.user.nowTimestamp"/>
            <entity-update value-field="amendment"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Transition Amendment Status Service                       -->
    <!-- ========================================================= -->
    <service verb="transition" noun="AmendmentStatus">
        <description>Internal service for amendment status transitions.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
            <parameter name="toStatusId" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment" for-update="true"/>
            <if condition="!amendment"><return error="true" message="Amendment not found."/></if>

            <!-- Validate transition using LcTransaction Flow -->
            <entity-find entity-name="moqui.basic.StatusFlowTransition" list="validTransitions">
                <econdition field-name="statusFlowId" value="LcTransaction"/>
                <econdition field-name="statusId" from="amendment.amendmentStatusId"/>
                <econdition field-name="toStatusId" from="toStatusId"/>
            </entity-find>
            
            <script>ec.logger.info(">>> AMENDMENT TRANSITION VALID: " + validTransitions?.size() + " from " + amendment.amendmentStatusId + " to " + toStatusId)</script>
            
            <!-- Allow transition if valid or if status matches the expected workflow -->
            <if condition="!validTransitions">
                <!-- For amendment workflow, allow transitions if they follow the expected pattern -->
                <set field="allowed" value="false"/>
                <if condition="amendment.amendmentStatusId == 'LcTxDraft' &amp;&amp; toStatusId == 'LcTxSubmitted'"><set field="allowed" value="true"/></if>
                <if condition="amendment.amendmentStatusId == 'LcTxSubmitted' &amp;&amp; (toStatusId == 'LcTxApproved' || toStatusId == 'LcTxRejected')"><set field="allowed" value="true"/></if>
                <if condition="amendment.amendmentStatusId == 'LcTxApproved' &amp;&amp; toStatusId == 'LcTxClosed'"><set field="allowed" value="true"/></if>
                <if condition="allowed == 'false'">
                    <return error="true" message="Invalid amendment status transition from ${amendment.amendmentStatusId} to ${toStatusId}."/>
                </if>
            </if>

            <set field="amendment.amendmentStatusId" from="toStatusId"/>
            <entity-update value-field="amendment"/>
            
            <!-- Release lock when amendment is rejected, cancelled, or closed -->
            <if condition="toStatusId == 'LcTxRejected' || toStatusId == 'LcTxCancelled' || toStatusId == 'LcTxClosed'">
                <service-call name="moqui.trade.finance.AmendmentServices.release#AmendmentLock" in-map="[lcId:lcId]"/>
            </if>
            

            <!-- Update linked Mantle Request status -->
            <if condition="amendment.requestId">
                <set field="reqStatusId" value=""/>
                <if condition="toStatusId == 'LcTxDraft'"><set field="reqStatusId" value="ReqDraft"/></if>
                <if condition="toStatusId == 'LcTxSubmitted'"><set field="reqStatusId" value="ReqSubmitted"/></if>
                <if condition="toStatusId == 'LcTxApproved'"><set field="reqStatusId" value="ReqReviewed"/></if>
                <if condition="toStatusId == 'LcTxClosed'"><set field="reqStatusId" value="ReqCompleted"/></if>
                <if condition="toStatusId == 'LcTxRejected'"><set field="reqStatusId" value="ReqCancelled"/></if>
                <if condition="toStatusId == 'LcTxCancelled'"><set field="reqStatusId" value="ReqCancelled"/></if>
                
                <if condition="reqStatusId">
                    <service-call name="update#mantle.request.Request" in-map="[requestId:amendment.requestId, statusId:reqStatusId]"/>
                </if>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Review Amendment by Supervisor Service                      -->
    <!-- ========================================================= -->
    <service verb="review" noun="LcAmendmentBySupervisor">
        <description>Supervisor reviews and approves/rejects amendment request.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
            <parameter name="approvalDecision" required="true"/>
            <parameter name="reviewComments"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment"/>
            <if condition="!amendment"><return error="true" message="Amendment not found."/></if>
            
            <if condition="approvalDecision == 'approve'">
                <service-call name="moqui.trade.finance.AmendmentServices.transition#AmendmentStatus"
                    in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId, toStatusId:'LcTxSupervisorApproved']"/>
                <log level="info" message="Amendment ${amendmentSeqId} approved by supervisor: ${reviewComments}"/>
            </if>
            <if condition="approvalDecision != 'approve'">
                <service-call name="moqui.trade.finance.AmendmentServices.transition#AmendmentStatus"
                    in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId, toStatusId:'LcTxRejected']"/>
                <log level="info" message="Amendment ${amendmentSeqId} rejected by supervisor: ${reviewComments}"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Approve Amendment by IPC Service                          -->
    <!-- ========================================================= -->
    <service verb="approve" noun="LcAmendmentByIpc">
        <description>IPC approves or rejects amendment at final level.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
            <parameter name="approvalDecision" required="true"/>
            <parameter name="ipcComments"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment"/>
            <if condition="!amendment"><return error="true" message="Amendment not found."/></if>
            
            <if condition="approvalDecision == 'approve'">
                <service-call name="moqui.trade.finance.AmendmentServices.transition#AmendmentStatus"
                    in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId, toStatusId:'LcTxIpcApproved']"/>
                <log level="info" message="Amendment ${amendmentSeqId} approved by IPC: ${ipcComments}"/>
            </if>
            <if condition="approvalDecision != 'approve'">
                <service-call name="moqui.trade.finance.AmendmentServices.transition#AmendmentStatus"
                    in-map="[lcId:lcId, amendmentSeqId:amendmentSeqId, toStatusId:'LcTxRejected']"/>
                <log level="info" message="Amendment ${amendmentSeqId} rejected by IPC: ${ipcComments}"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Record Beneficiary Response Service                        -->
    <!-- ========================================================= -->
    <service verb="record" noun="BeneficiaryResponse">
        <description>Records beneficiary acceptance or rejection of amendment.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
            <parameter name="responseTypeEnumId" required="true"/>
            <parameter name="beneficiaryPartyId"/>
            <parameter name="contactName"/>
            <parameter name="contactMethod"/>
            <parameter name="responseReference"/>
            <parameter name="reason"/>
        </in-parameters>
        <out-parameters>
            <parameter name="responseId"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment"/>
            <if condition="!amendment"><return error="true" message="Amendment not found."/></if>
            
            <service-call name="create#moqui.trade.finance.LcAmendmentBeneficiaryResponse" out-map="context" in-map="[
                responseDate:ec.user.nowTimestamp,
                receivedByUserId:ec.user.userId
            ]"/>
            <set field="responseId" from="responseId"/>
            
            <if condition="responseTypeEnumId == 'LcAmndAccept'">
                <set field="amendment.confirmationStatusId" value="LcAmndConfirmed"/>
            </if>
            <if condition="responseTypeEnumId != 'LcAmndAccept'">
                <set field="amendment.confirmationStatusId" value="LcAmndReject"/>
            </if>
            <entity-update value-field="amendment"/>
            
            <log level="info" message="Recorded beneficiary ${responseTypeEnumId} for amendment ${amendmentSeqId}"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Get Amendment History Service                              -->
    <!-- ========================================================= -->
    <service verb="get" noun="AmendmentHistory">
        <description>Retrieves amendment history for an LC.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId"/>
        </in-parameters>
        <out-parameters>
            <parameter name="historyList"/>
        </out-parameters>
        <actions>
            <entity-find entity-name="moqui.trade.finance.LcAmendment" list="amendments">
                <econdition field-name="lcId"/>
                <econdition field-name="amendmentSeqId"/>
                <order-by field-name="-amendmentDate"/>
            </entity-find>
            
            <entity-find entity-name="moqui.trade.finance.LcAmendmentBeneficiaryResponse" list="responses">
                <econdition field-name="lcId"/>
                <econdition field-name="amendmentSeqId"/>
                <order-by field-name="-responseDate"/>
            </entity-find>
            
            <set field="historyList" from="[amendments:amendments, responses:responses]"/>
            <log level="info" message="Retrieved ${amendments.size()} amendments for LC ${lcId}"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Get Effective Terms Service                                -->
    <!-- ========================================================= -->
    <service verb="get" noun="EffectiveTerms">
        <description>Retrieves effective LC terms after amendments.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="effectiveAmount"/>
            <parameter name="effectiveExpiryDate"/>
            <parameter name="amendmentNumber"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="!lc"><return error="true" message="LC not found."/></if>
            
            <set field="effectiveAmount" from="lc.amount"/>
            <set field="effectiveExpiryDate" from="lc.expiryDate"/>
            <set field="amendmentNumber" from="lc.amendmentNumber"/>
            
            <log level="info" message="Retrieved effective terms for LC ${lcId}: amount=${effectiveAmount}, amendment#=${amendmentNumber}"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Adjust Provisions for Amendment Service                     -->
    <!-- ========================================================= -->
    <service verb="adjust" noun="ProvisionsForAmendment">
        <description>Adjusts provisions when LC amount changes via amendment.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="amendmentSeqId" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendment" value-field="amendment"/>
            <if condition="!lc || !amendment"><return error="true" message="LC or Amendment not found."/></if>
            
            <set field="originalAmount" from="lc.amount"/>
            <set field="amendedAmount" from="amendment.amount ?: lc.amount"/>
            
            <if condition="amendedAmount != originalAmount">
                <service-call name="moqui.trade.finance.FinancialServices.adjust#LcProvision"
                    in-map="[lcId:lcId, newAmount:amendedAmount]"/>
                <log level="info" message="Adjusted provisions for amendment ${amendmentSeqId}: ${originalAmount} -> ${amendedAmount}"/>
            </if>
            <if condition="amendedAmount == originalAmount">
                <log level="info" message="No provision adjustment needed - amount unchanged for amendment ${amendmentSeqId}"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Acquire Amendment Lock Service                             -->
    <!-- ========================================================= -->
    <service verb="acquire" noun="AmendmentLock">
        <description>Acquires a lock on LC for amendment processing.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="lockTimeoutMinutes" type="Integer" default="30"/>
        </in-parameters>
        <out-parameters>
            <parameter name="lockAcquired"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendmentLock" value-field="existingLock"/>
            
            <if condition="existingLock">
                <set field="lockAcquired" value="false"/>
                <return error="true" message="LC is currently locked for amendment by ${existingLock.lockedByUserId}."/>
            </if>
            <if condition="!existingLock">
                <set field="now" from="ec.user.nowTimestamp"/>
                <set field="expiry" from="new java.sql.Timestamp(now.getTime() + lockTimeoutMinutes * 60000)"/>
                
                <service-call name="create#moqui.trade.finance.LcAmendmentLock" in-map="[
                    lcId:lcId,
                    lockType:'AMENDMENT',
                    lockedByUserId:ec.user.userId,
                    lockedAt:now,
                    lockExpiry:expiry
                ]"/>
                
                <set field="lockAcquired" value="true"/>
                <log level="info" message="Acquired amendment lock for LC ${lcId} by user ${ec.user.userId}"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Release Amendment Lock Service                             -->
    <!-- ========================================================= -->
    <service verb="release" noun="AmendmentLock">
        <description>Releases the amendment lock on an LC.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendmentLock" value-field="lock"/>
            
            <if condition="lock">
                <entity-delete value-field="lock"/>
                <log level="info" message="Released amendment lock for LC ${lcId}"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Check Amendment Lock Status Service                        -->
    <!-- ========================================================= -->
    <service verb="check" noun="AmendmentLockStatus">
        <description>Checks the lock status of an LC for amendment.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="isLocked"/>
            <parameter name="lockedByUserId"/>
            <parameter name="lockExpiry"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendmentLock" value-field="lock"/>
            
            <if condition="lock">
                <set field="isLocked" value="true"/>
                <set field="lockedByUserId" from="lock.lockedByUserId"/>
                <set field="lockExpiry" from="lock.lockExpiry"/>
            </if>
            <if condition="!lock">
                <set field="isLocked" value="false"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Force Release Amendment Lock Service                       -->
    <!-- ========================================================= -->
    <service verb="forceRelease" noun="AmendmentLock">
        <description>Force releases a stale lock on an LC. Requires admin authentication.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="reason"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LcAmendmentLock" value-field="lock"/>
            
            <if condition="lock">
                <set field="originalUser" from="lock.lockedByUserId"/>
                <entity-delete value-field="lock"/>
                <log level="info" message="Force released amendment lock for LC ${lcId} - was locked by ${originalUser}. Reason: ${reason}"/>
            </if>
            <if condition="!lock">
                <log level="info" message="No lock found for LC ${lcId}"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Get All Active Locks Service                                 -->
    <!-- ========================================================= -->
    <service verb="get" noun="AllActiveLocks">
        <description>Retrieves all active (non-expired) amendment locks for admin management screen.</description>
        <in-parameters>
            <parameter name="filterLcNumber"/>
            <parameter name="filterUserId"/>
        </in-parameters>
        <out-parameters>
            <parameter name="lockList"/>
        </out-parameters>
        <actions>
            <set field="lockList" from="[]"/>
            <set field="now" from="ec.user.nowTimestamp"/>
            
            <script><![CDATA[
                // Resolve lcNumber to lcId if provided
                def filterLcId = null
                if (filterLcNumber && filterLcNumber.trim()) {
                    def lc = ec.entity.find("moqui.trade.finance.LetterOfCredit").condition("lcNumber", filterLcNumber).one()
                    if (lc) filterLcId = lc.lcId
                }
                
                // Get all locks
                def allLocks = ec.entity.find("moqui.trade.finance.LcAmendmentLock").orderBy("-lockedAt").list()
                
                // Filter to only active locks (no expiry or expiry > now)
                def locks = allLocks.findAll { lock ->
                    (!lock.lockExpiry || lock.lockExpiry > now)
                }
                
                // Apply filters
                if (filterLcId) {
                    locks = locks.findAll { it.lcId == filterLcId }
                }
                if (filterUserId && filterUserId.trim()) {
                    locks = locks.findAll { it.lockedByUserId == filterUserId }
                }
                
                // Enrich locks with LC number
                def enrichedList = []
                locks.each { lock ->
                    def lc = ec.entity.find("moqui.trade.finance.LetterOfCredit").condition("lcId", lock.lcId).one()
                    enrichedList.add([
                        lcId: lock.lcId,
                        lcNumber: lc?.lcNumber ?: 'Unknown',
                        userId: lock.lockedByUserId,
                        acquiredTime: lock.lockedAt,
                        expireTime: lock.lockExpiry,
                        lockType: lock.lockType,
                        amendmentSeqId: lock.amendmentSeqId
                    ])
                }
                lockList = enrichedList
            ]]></script>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Get Locked LC Numbers for Dropdown                        -->
    <!-- ========================================================= -->
    <service verb="get" noun="LockedLcNumbers">
        <description>Returns list of LC numbers that have active locks, for dropdown population.</description>
        <out-parameters>
            <parameter name="lcNumberList"/>
        </out-parameters>
        <actions>
            <entity-find entity-name="moqui.trade.finance.LcAmendmentLock" list="locks">
                <select-field field-name="lcId"/>
            </entity-find>
            <set field="lcIds" from="locks*.lcId"/>
            
            <entity-find entity-name="moqui.trade.finance.LetterOfCredit" list="lcs">
                <econdition field-name="lcId" operator="in" from="lcIds"/>
                <select-field field-name="lcId"/>
                <select-field field-name="lcNumber"/>
            </entity-find>
            
            <set field="lcNumberList" from="lcs*.lcNumber"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Expire Locks Service                                        -->
    <!-- ========================================================= -->
    <service verb="expire" noun="Locks">
        <description>Automatically expires locks that have passed their expiry time.</description>
        <actions>
            <set field="now" from="ec.user.nowTimestamp"/>
            
            <entity-find entity-name="moqui.trade.finance.LcAmendmentLock" list="expiredLocks">
                <econdition field-name="lockExpiry" operator="less-equals" from="now"/>
            </entity-find>
            
            <script>
                expiredLocks.each { lock ->
                    lock.delete()
                    ec.logger.info("Auto-expired amendment lock for LC: " + lock.lcId)
                }
            </script>
            
            <log level="info" message="Expired ${expiredLocks?.size()} amendment locks"/>
        </actions>
    </service>

</services>
