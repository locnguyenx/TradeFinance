<?xml version="1.0" encoding="UTF-8"?>
<!-- CbsIntegrationServices.xml
     Architectural seam (interfaces) for Core Banking System (CBS) integration.
     In a real deployment, these would connect to the bank's external APIs. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd"
          package="moqui.trade.finance">

    <!-- ========================================================= -->
    <!-- Funds Hold / Release Interfaces                           -->
    <!-- ========================================================= -->
    <!-- Interface services that route to specific implementations -->

    <service verb="hold" noun="Funds">
        <description>Places a hold on a customer's account for LC provisions/margins.</description>
        <in-parameters>
            <parameter name="partyId" required="true"/>
            <parameter name="amount" type="BigDecimal" required="true"/>
            <parameter name="currencyUomId" required="true"/>
            <parameter name="referenceId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="holdReference"/>
            <parameter name="success" type="Boolean"/>
            <parameter name="message"/>
        </out-parameters>
        <actions>
            <set field="implSuffix" value="${System.getProperty('cbs.integration.impl') ?: 'Mock'}"/>
            <service-call name="moqui.trade.finance.Cbs${implSuffix}Services.hold#Funds${implSuffix}" 
                          in-map="context" out-map="context"/>
        </actions>
    </service>

    <service verb="release" noun="Funds">
        <implements service="moqui.trade.finance.CbsIntegrationServices.hold#Funds"/> <!-- reused parameters -->
        <in-parameters><parameter name="holdReference" required="true"/></in-parameters>
        <actions>
            <set field="implSuffix" value="${System.getProperty('cbs.integration.impl') ?: 'Mock'}"/>
            <service-call name="moqui.trade.finance.Cbs${implSuffix}Services.release#Funds${implSuffix}" 
                          in-map="context" out-map="context"/>
        </actions>
    </service>

    <service verb="post" noun="AccountingEntries">
        <in-parameters>
            <parameter name="debitAccountId" required="true"/><parameter name="creditAccountId" required="true"/>
            <parameter name="amount" type="BigDecimal" required="true"/><parameter name="currencyUomId" required="true"/>
            <parameter name="transactionType" required="true"/><parameter name="referenceId"/>
        </in-parameters>
        <out-parameters><parameter name="transactionReference"/><parameter name="success" type="Boolean"/></out-parameters>
        <actions>
            <set field="implSuffix" value="${System.getProperty('cbs.integration.impl') ?: 'Mock'}"/>
            <service-call name="moqui.trade.finance.Cbs${implSuffix}Services.post#AccountingEntries${implSuffix}" 
                          in-map="context" out-map="context"/>
        </actions>
    </service>

    <service verb="check" noun="CreditLimit">
        <in-parameters>
            <parameter name="partyId" required="true"/>
            <parameter name="limitType" default-value="TRADE_LC"/>
            <parameter name="creditAgreementId"/>
        </in-parameters>
        <out-parameters><parameter name="availableLimit" type="BigDecimal"/><parameter name="currencyUomId"/></out-parameters>
        <actions>
            <set field="implSuffix" value="${System.getProperty('cbs.integration.impl') ?: 'Mock'}"/>
            <service-call name="moqui.trade.finance.Cbs${implSuffix}Services.check#CreditLimit${implSuffix}" 
                          in-map="context" out-map="context"/>
        </actions>
    </service>

    <service verb="get" noun="ExchangeRate">
        <in-parameters><parameter name="fromCurrencyUomId" required="true"/><parameter name="toCurrencyUomId" required="true"/></in-parameters>
        <out-parameters><parameter name="exchangeRate" type="BigDecimal"/></out-parameters>
        <actions>
            <!-- FX Rate usually doesn't need a complex adapter, but pattern kept for consistency -->
            <if condition="fromCurrencyUomId == toCurrencyUomId"><set field="exchangeRate" value="1.0"/><return/></if>
            <set field="implSuffix" value="${System.getProperty('cbs.integration.impl') ?: 'Mock'}"/>
            <!-- Fallback to inline mock if impl not found or just use Mock -->
            <if condition="implSuffix == 'Mock'">
                <if condition="fromCurrencyUomId == 'USD' &amp;&amp; toCurrencyUomId == 'EUR'"><set field="exchangeRate" value="0.92"/>
                <else-if condition="fromCurrencyUomId == 'EUR' &amp;&amp; toCurrencyUomId == 'USD'"><set field="exchangeRate" value="1.09"/></else-if>
                <else><set field="exchangeRate" value="1.0"/></else></if>
            <else>
                <!-- Placeholder for real FX API -->
                <set field="exchangeRate" value="1.0"/>
            </else>
            </if>
        </actions>
    </service>

</services>
