<?xml version="1.0" encoding="UTF-8"?>
<!-- TradeFinanceServices.xml
     Core services for the Trade Finance component.
     Includes LC CRUD, validation, status transitions, and Mantle Request integration. -->
<services xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/service-definition-3.xsd"
          package="moqui.trade.finance">

    <!-- ========================================================= -->
    <!-- Validation Service                                        -->
    <!-- ========================================================= -->
    <service verb="validate" noun="LetterOfCredit">
        <description>Validates LC fields against SWIFT Character Set X and UCP 600 rules.</description>
        <in-parameters>
            <auto-parameters entity-name="moqui.trade.finance.LetterOfCredit" include="nonpk"/>
            <parameter name="isStrict" type="Boolean" default="false"/>
        </in-parameters>
        <actions>
            <!-- SWIFT Character Set X and length validations always apply -->
            
            <log level="info" message="Validating LC fields (Strict:${isStrict}): ${context}"/>
            <script><![CDATA[
                // SWIFT Character Set X: A-Z, a-z, 0-9, / - ? : ( ) . , ' + space, CR, LF
                def swiftXPattern = /^[A-Za-z0-9\/\-\?\:\(\)\.\,\'\+ \r\n]*$/
                
                // Character Set X and Length validation should ALWAYS apply to these fields if they have values
                def pattern = java.util.regex.Pattern.compile(swiftXPattern)
                def fieldsToCheck = [
                    issuingBankName: 140, issuingBankAddress: 140, advisingBankName: 140, advisingThroughBank_57a: 140,
                    negotiatingBankName: 140, confirmingBankName: 140, requestedConfirmationParty_58a: 140,
                    portOfLoading_44E: 65, portOfDischarge_44F: 65, placeOfFinalDest_44G: 65,
                    descriptionOfGoods_45A: 6500, documentsRequired_46A: 6500,
                    additionalConditions_47A: 6500, instructionsToBank_78: 6500,
                    specialPaymentCond_47B: 6500, charges_71B: 6500,
                    lcNumber: 16, applicantName: 140, beneficiaryName: 140
                ]
                fieldsToCheck.each { fieldName, maxLength ->
                    def value = context[fieldName]
                    if (value instanceof String && value.trim()) {
                        ec.logger.info("Checking field ${fieldName}: [${value}]")
                        // Character Set X Validation
                        if (!pattern.matcher(value).matches()) {
                            def failingMatcher = (value =~ /[^A-Za-z0-9\/\-\?\:\(\)\.\,\'\+ \r\n]/)
                            if (failingMatcher.find()) {
                                def badChar = failingMatcher.group()
                                def hex = "0x" + Integer.toHexString((int)badChar[0]).toUpperCase()
                                ec.message.addError("Field ${fieldName} contains character '${badChar}' (${hex}) not allowed in SWIFT Character Set X")
                            }
                        }
                        // Length Validation
                        if (maxLength && value.length() > maxLength) {
                            ec.message.addError("${fieldName} (${maxLength}) exceeds ${maxLength} character limit: [${value}] (length: ${value.length()})")
                        }
                    }
                }
            ]]></script>
            <script>ec.logger.info("Finished script validation. Errors? " + ec.message.hasError())</script>

            <!-- UCP 600: Expiry Date must be after Issue Date -->
            <if condition="expiryDate &amp;&amp; issueDate &amp;&amp; expiryDate &lt; issueDate">
                <message error="true">Expiry Date must be after Issue Date per UCP 600 guidelines.</message>
            </if>

            <!-- SWIFT field length validations -->
            <script>
                if (lcNumber &amp;&amp; lcNumber.length() > 16) {
                    ec.message.addError("LC Number (20) exceeds 16 character limit: [${lcNumber}] (length: ${lcNumber.length()})")
                }
                if (applicantName &amp;&amp; applicantName.length() > 140) {
                    ec.message.addError("Applicant Name (50) exceeds 140 character limit: [${applicantName}] (length: ${applicantName.length()})")
                }
                if (beneficiaryName &amp;&amp; beneficiaryName.length() > 140) {
                    ec.message.addError("Beneficiary Name (59) exceeds 140 character limit: [${beneficiaryName}] (length: ${beneficiaryName.length()})")
                }
            </script>
            <if condition="descriptionOfGoods_45A &amp;&amp; descriptionOfGoods_45A.length() > 6500">
                <message error="true">Goods Description (45A) exceeds 6500 character limit.</message></if>
            <if condition="amountTolerance_39A &amp;&amp; !(amountTolerance_39A ==~ /^[0-9]{1,2}\/[0-9]{1,2}$/)">
                <message error="true">Amount Tolerance (39A) must be in format n/n (e.g. 10/10): [${amountTolerance_39A}]</message>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Create LC Service                                         -->
    <!-- Creates a LetterOfCredit with initial statuses and a      -->
    <!-- linked Mantle Request for workflow processing.             -->
    <!-- ========================================================= -->
    <service verb="create" noun="LetterOfCredit">
        <description>Creates a new Letter of Credit with Draft status and a linked Mantle Request.</description>
        <in-parameters>
            <auto-parameters entity-name="moqui.trade.finance.LetterOfCredit" include="nonpk"/>
            <parameter name="lcNumber" required="true"/>
            <!-- Default: begin in Draft state for both lifecycle and transaction -->
            <parameter name="lcStatusId" default-value="LcLfDraft"/>
            <parameter name="transactionStatusId" default-value="LcTxDraft"/>
            <parameter name="comments"/>
        </in-parameters>
        <out-parameters>
            <parameter name="lcId"/>
            <parameter name="requestId"/>
        </out-parameters>
        <actions>
            <log level="info" message="Creating Letter of Credit for applicant: ${applicantPartyId ?: applicantName}"/>
            
            <!-- Validate mandatory fields for LC creation -->
            <if condition="!productId"><message error="true">Product is required.</message></if>
            <if condition="!lcNumber"><message error="true">LC Number is required.</message></if>
            <if condition="!applicantPartyId"><message error="true">Applicant Party is required.</message></if>
            <if condition="!beneficiaryPartyId"><message error="true">Beneficiary Party is required.</message></if>
            <if condition="!amount"><message error="true">Amount is required.</message></if>
            <if condition="!amountCurrencyUomId"><message error="true">Currency is required.</message></if>
            <if condition="!expiryDate"><message error="true">Expiry Date is required.</message></if>
            <check-errors/>
            
            <!-- Validate SWIFT Character Set X and other field validations -->
            <service-call name="moqui.trade.finance.TradeFinanceServices.validate#LetterOfCredit" in-map="context"/>
            <check-errors/>

            <!-- Create the Mantle Request for inter-department workflow tracking -->
            <service-call name="create#mantle.request.Request" out-map="reqOut"
                in-map="[requestTypeEnumId:'RqtLcIssuance', statusId:'ReqDraft',
                         requestName:('LC Issuance: ' + lcNumber),
                         description:('Letter of Credit issuance request for ' + lcNumber)]"/>
            <set field="requestId" from="reqOut.requestId"/>

            <!-- Fetch Product Defaults -->
            <if condition="productId">
                <entity-find-one entity-name="moqui.trade.finance.LcProduct" value-field="product"/>
                <if condition="product">
                    <set field="lcProductTypeEnumId" from="product.lcProductTypeEnumId"/>
                    <!-- Default provision rate from product if not manually specified -->
                    <if condition="provisionRate == null">
                        <set field="provisionRate" from="product.defaultProvisionRate"/>
                    </if>
                </if>
            </if>

            <!-- Create the LetterOfCredit record -->
            <service-call name="create#moqui.trade.finance.LetterOfCredit" in-map="context" out-map="newLcOut"/>
            <set field="lcId" from="newLcOut.lcId"/>

            <!-- Automated Assessment of Charges and Provisions (R8.11 Scenario 3) -->
            <if condition="product">
                <service-call name="moqui.trade.finance.FinancialServices.calculate#LcChargesAndProvisions"
                    in-map="[lcId:lcId]"/>
            </if>

            <!-- Record initial history entry -->
            <service-call name="create#moqui.trade.finance.LcHistory"
                in-map="[lcId:lcId, changeType:'StatusChange', fieldName:'lcStatusId',
                         newValue:lcStatusId, changedByUserId:ec.user.userId,
                         comments:comments ?: ('LC application created for product: ' + (product?.productName ?: 'N/A'))]"/>

            <!-- Send Notification -->
            <service-call name="moqui.trade.finance.NotificationServices.send#LcNotification"
                in-map="[lcId:lcId, eventDescription:'Draft']"/>

            <log level="info" message="Successfully created LC with ID: ${lcId}"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Update LC Service                                         -->
    <!-- Updates LC fields and records changes in history.          -->
    <!-- ========================================================= -->
    <service verb="update" noun="LetterOfCredit">
        <description>Updates an existing Letter of Credit, ensuring validation and recording history.</description>
        <in-parameters>
            <auto-parameters entity-name="moqui.trade.finance.LetterOfCredit" include="nonpk"/>
            <parameter name="lcId" required="true"/>
        </in-parameters>
        <actions>
            <service-call name="moqui.trade.finance.TradeFinanceServices.validate#LetterOfCredit" in-map="context"/>
            <check-errors/>
            
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            
            <!-- Audit changes to history -->
            <service-call name="create#moqui.trade.finance.LcHistory"
                in-map="[lcId:lcId, changeDate:ec.user.nowTimestamp, changeType:'Update', 
                         fieldName:'General', newValue:'LC Updated']"/>
            
            <service-call name="update#moqui.trade.finance.LetterOfCredit" in-map="context"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Submit LC Service                                         -->
    <!-- Performs strict validation and transitions to Submitted.  -->
    <!-- ========================================================= -->
    <service verb="submit" noun="LetterOfCredit">
        <description>Submits a Draft LC for bank review. Performs strict validation.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="comments"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="!lc"><return error="true" message="Letter of Credit not found."/></if>

            <!-- Check current state -->
            <if condition="lc.transactionStatusId != 'LcTxDraft' &amp;&amp; lc.transactionStatusId != 'LcTxReturned'">
                <return error="true" message="Only Draft or Returned LCs can be submitted for review."/>
            </if>

            <!-- BDD-R8.3-UC4-SC2: Check for required documents before submission -->
            <entity-find entity-name="moqui.trade.finance.LcDocument" list="existingDocs">
                <econdition field-name="lcId"/></entity-find>
            <if condition="!existingDocs">
                <return error="true" message="Cannot submit. Please attach all required documents."/>
            </if>

            <!-- Strict Validation -->
            <script>validateIn = lc.getMap(); validateIn.isStrict = true</script>
            <service-call name="moqui.trade.finance.TradeFinanceServices.validate#LetterOfCredit"
                in-map="validateIn"/>
            <check-errors/>

            <!-- Transition to Pending Review -->
            <service-call name="moqui.trade.finance.TradeFinanceServices.transition#TransactionStatus"
                in-map="[lcId:lcId, toStatusId:'LcTxPendingReview', comments:comments ?: 'Submitted for review']"/>
            
            <!-- LC Status remains Draft until Approval as per BRD 5.2 -->

            <!-- Update Mantle Request Status -->
            <if condition="lc.requestId">
                <service-call name="update#mantle.request.Request"
                    in-map="[requestId:lc.requestId, statusId:'ReqSubmitted']"/>
            </if>

            <log level="info" message="LC ID ${lcId} successfully submitted for review."/>
        </actions>
    </service>

    <service verb="approve" noun="LcBySupervisor">
        <description>Branch Supervisor approves and submits for processing.</description>
        <in-parameters><parameter name="lcId" required="true"/><parameter name="comments"/></in-parameters>
        <actions>
            <service-call name="moqui.trade.finance.TradeFinanceServices.transition#TransactionStatus"
                in-map="[lcId:lcId, toStatusId:'LcTxPendingProcessing', comments:comments ?: 'Supervisor approved']"/>
        </actions>
    </service>

    <service verb="approve" noun="LcByTradeOperator">
        <description>Trade Operator submits for final approval. Calculates charges/provisions and holds funds.</description>
        <in-parameters><parameter name="lcId" required="true"/><parameter name="comments"/></in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            
            <!-- Automated Charge & Provision Calculation -->
            <service-call name="moqui.trade.finance.FinancialServices.calculate#LcChargesAndProvisions"
                in-map="[lcId:lcId]"/>
            
            <!-- CBS Funds Hold for Provision -->
            <entity-find entity-name="moqui.trade.finance.LcProvision" list="provisions">
                <econdition field-name="lcId"/><econdition field-name="provisionStatusId" value="LcPrvDraft"/></entity-find>
            <iterate list="provisions" entry="provision">
                <!-- Use standard hold service for robust error handling and status transitions -->
                <service-call name="moqui.trade.finance.FinancialServices.hold#LcProvision"
                    in-map="[lcId:lcId, provisionAmount:provision.provisionAmount]"/>
            </iterate>

            <!-- CBS Accounting Entry for Upfront Charges -->
            <entity-find entity-name="moqui.trade.finance.LcCharge" list="charges">
                <econdition field-name="lcId"/><econdition field-name="waived" value="N"/></entity-find>
            <iterate list="charges" entry="charge">
                <service-call name="moqui.trade.finance.CbsIntegrationServices.post#AccountingEntries"
                    in-map="[debitAccountId:'CUST_OPER_ACC', creditAccountId:'BANK_COMM_ACC', 
                             amount:charge.chargeAmount, currencyUomId:charge.chargeCurrencyUomId,
                             transactionType:'CHARGE_COLLECTION', referenceId:lcId]"
                    out-map="postOut"/>
                <if condition="!postOut.success">
                    <return error="true" message="Failed to collect charge ${charge.chargeTypeEnumId}: ${postOut.message}"/>
                </if>
            </iterate>

            <service-call name="moqui.trade.finance.TradeFinanceServices.transition#TransactionStatus"
                in-map="[lcId:lcId, toStatusId:'LcTxPendingApproval', comments:comments ?: 'Processed by Trade Ops']"/>
        </actions>
    </service>

    <service verb="approve" noun="LcByTradeSupervisor">
        <description>Final approval by Trade Supervisor. Transitions LC Status to Applied.</description>
        <in-parameters><parameter name="lcId" required="true"/><parameter name="comments"/></in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            
            <service-call name="moqui.trade.finance.TradeFinanceServices.transition#TransactionStatus"
                in-map="[lcId:lcId, toStatusId:'LcTxApproved', comments:comments ?: 'Final Approval']"/>
            
            <!-- Per BRD 5.2: Approved Transaction -> LC Status = Applied -->
            <service-call name="moqui.trade.finance.TradeFinanceServices.transition#LcStatus"
                in-map="[lcId:lcId, toStatusId:'LcLfApplied']"/>
            
            <if condition="lc?.requestId">
                <service-call name="update#mantle.request.Request"
                    in-map="[requestId:lc.requestId, statusId:'ReqCompleted']"/>
            </if>
        </actions>
    </service>

    <service verb="return" noun="LetterOfCredit">
        <description>Returns the LC to Draft/Returned for corrections.</description>
        <in-parameters><parameter name="lcId" required="true"/><parameter name="comments" required="true"/></in-parameters>
        <actions>
            <service-call name="moqui.trade.finance.TradeFinanceServices.transition#TransactionStatus"
                in-map="[lcId:lcId, toStatusId:'LcTxReturned', comments:comments]"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Delete LC Service                                         -->
    <!-- Only allowed for LCs in Draft transaction status.          -->
    <!-- ========================================================= -->
    <service verb="delete" noun="LetterOfCredit">
        <description>Deletes an LC Draft. Only allowed if in LcTxDraft status.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="!lc"><message error="true">LC [${lcId}] not found.</message><check-errors/></if>
            
            <if condition="lc.transactionStatusId != 'LcTxDraft'">
                <message error="true">Only draft LCs can be deleted.</message>
                <return/>
            </if>

            <!-- Cascade delete related records to avoid FK constraint violations -->
            <!-- Delete drawing sub-entities first (discrepancies, drawing documents) -->
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcDiscrepancy">
                <econdition field-name="lcId"/></entity-delete-by-condition>
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcDrawingDocument">
                <econdition field-name="lcId"/></entity-delete-by-condition>
            <!-- Delete main related entities -->
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcDrawing">
                <econdition field-name="lcId"/></entity-delete-by-condition>
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcAmendment">
                <econdition field-name="lcId"/></entity-delete-by-condition>
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcCharge">
                <econdition field-name="lcId"/></entity-delete-by-condition>
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcProvision">
                <econdition field-name="lcId"/></entity-delete-by-condition>
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcDocument">
                <econdition field-name="lcId"/></entity-delete-by-condition>
            <entity-delete-by-condition entity-name="moqui.trade.finance.LcHistory">
                <econdition field-name="lcId"/></entity-delete-by-condition>

            <!-- Delete the main LC record -->
            <service-call name="delete#moqui.trade.finance.LetterOfCredit" in-map="[lcId:lcId]"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Transition LC Status Service                              -->
    <!-- Validates the transition using StatusFlowTransition and   -->
    <!-- updates the status field accordingly.                     -->
    <!-- ========================================================= -->
    <service verb="transition" noun="LcStatus">
        <description>Transitions the LC lifecycle status using StatusFlow validation.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="toStatusId" required="true"/>
            <parameter name="comments"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc" for-update="true"/>
            <if condition="!lc"><return error="true" message="Letter of Credit not found."/></if>

            <!-- Validate the transition is allowed by the StatusFlow -->
            <entity-find entity-name="moqui.basic.StatusFlowTransition" list="validTransitions">
                <econdition field-name="statusFlowId" value="LcLifecycle"/>
                <econdition field-name="statusId" from="lc.lcStatusId"/>
                <econdition field-name="toStatusId" from="toStatusId"/>
            </entity-find>
            <if condition="!validTransitions">
                <return error="true" message="Invalid LC status transition from ${lc.lcStatusId} to ${toStatusId}."/>
            </if>

            <!-- R8.11: Mandatory Charge Validation during Issuance -->
            <if condition="toStatusId == 'LcLfIssued'">
                <entity-find entity-name="moqui.trade.finance.LcProductCharge" list="mandatoryProductCharges">
                    <econdition field-name="productId" from="lc.productId"/>
                    <econdition field-name="isMandatory" value="Y"/>
                </entity-find>
                
                <iterate list="mandatoryProductCharges" entry="prodCharge">
                    <entity-find entity-name="moqui.trade.finance.LcCharge" list="lcCharges">
                        <econdition field-name="lcId"/>
                        <econdition field-name="chargeTypeEnumId" from="prodCharge.chargeTypeEnumId"/>
                        <econdition field-name="waived" value="N"/>
                    </entity-find>
                    <if condition="!lcCharges">
                        <return error="true" message="Mandatory charge ${prodCharge.chargeTypeEnumId} is missing or waived. Issuance blocked."/>
                    </if>
                </iterate>

                <!-- R8.4/R8.11: Final SWIFT validation before issuance -->
                <service-call name="moqui.trade.finance.TradeFinanceServices.validate#LetterOfCredit" in-map="lc"/>
                <check-errors/>
            </if>

            <!-- Record old value for history -->
            <set field="oldStatusId" from="lc.lcStatusId"/>
            <script>lc.lcStatusId = toStatusId</script>
            <entity-update value-field="lc"/>

            <!-- Record the transition in history -->
            <service-call name="create#moqui.trade.finance.LcHistory"
                in-map="[lcId:lcId, changeType:'StatusChange', fieldName:'lcStatusId',
                         oldValue:oldStatusId, newValue:toStatusId,
                         changedByUserId:ec.user.userId,
                         comments:comments ?: ('LC status: ' + oldStatusId + ' -> ' + toStatusId)]"/>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- Transition Transaction Status Service                     -->
    <!-- Validates and transitions the processing status.          -->
    <!-- ========================================================= -->
    <service verb="transition" noun="TransactionStatus">
        <description>Transitions the LC transaction processing status using StatusFlow validation.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="toStatusId" required="true"/>
            <parameter name="comments"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc" for-update="true"/>
            <if condition="!lc"><return error="true" message="Letter of Credit not found."/></if>

            <log level="info" message="Attempting transition for LC ${lcId} from ${lc.transactionStatusId} to ${toStatusId}"/>
            <!-- Validate the transition is allowed by the StatusFlow -->
            <entity-find entity-name="moqui.basic.StatusFlowTransition" list="validTransitions">
                <econdition field-name="statusFlowId" value="LcTransaction"/>
                <econdition field-name="statusId" from="lc.transactionStatusId"/>
                <econdition field-name="toStatusId" from="toStatusId"/>
            </entity-find>
            <if condition="!validTransitions">
                <log level="warn" message="No transition found in StatusFlowTransition for LcTransaction: ${lc.transactionStatusId} -> ${toStatusId}"/>
                <!-- Diagnostic: List all transitions for this flow -->
                <entity-find entity-name="moqui.basic.StatusFlowTransition" list="allTransitions">
                    <econdition field-name="statusFlowId" value="LcTransaction"/>
                </entity-find>
                <log level="warn" message="Available transitions in LcTransaction flow: ${allTransitions}"/>
                <return error="true" message="Invalid transaction status transition from ${lc.transactionStatusId} to ${toStatusId}."/>
            </if>

            <!-- Record old value for history -->
            <set field="oldStatusId" from="lc.transactionStatusId"/>
            <set field="lc.transactionStatusId" from="toStatusId"/>
            <if condition="comments"><set field="lc.comments" from="comments"/></if>
            <entity-update value-field="lc"/>

            <!-- Record the transition in history -->
            <service-call name="create#moqui.trade.finance.LcHistory"
                in-map="[lcId:lcId, changeType:'StatusChange', fieldName:'transactionStatusId',
                         oldValue:oldStatusId, newValue:toStatusId,
                         changedByUserId:ec.user.userId,
                         comments:comments ?: ('Transaction status: ' + oldStatusId + ' -> ' + toStatusId)]"/>

            <!-- Send Notification for major transitions -->
            <if condition="toStatusId == 'LcTxSubmitted'">
                <service-call name="moqui.trade.finance.NotificationServices.send#LcNotification"
                               in-map="[lcId:lcId, eventDescription:'LC Application Submitted for Review']"/>
            </if>
            <if condition="toStatusId == 'LcTxApproved'">
                <service-call name="moqui.trade.finance.NotificationServices.send#LcNotification"
                               in-map="[lcId:lcId, eventDescription:'LC Application Approved']"/>
            </if>
        </actions>
    </service>

    <!-- ========================================================= -->
    <!-- BRD Implementation Services                               -->
    <!-- ========================================================= -->

    <service verb="update" noun="LcApplicationDetail">
        <description>Updates additional information for LC application (Collateral, Credit Agreement - Step 4).</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="isSecured" type="String"/> <!-- Y/N -->
            <parameter name="securedPercentage" type="BigDecimal"/>
            <parameter name="creditAgreementId"/>
            <parameter name="collateralDescription"/>
        </in-parameters>
        <actions>
            <service-call name="moqui.trade.finance.TradeFinanceServices.update#LetterOfCredit" in-map="context"/>
            
            <!-- If creditAgreementId is provided, automatically check limit -->
            <if condition="creditAgreementId">
                <service-call name="moqui.trade.finance.TradeFinanceServices.check#CustomerCreditLimit"
                    in-map="[lcId:lcId, creditAgreementId:creditAgreementId]"/>
            </if>
        </actions>
    </service>

    <service verb="check" noun="CustomerCreditLimit">
        <description>Retrieves customer credit limit from CBS and updates the LC record.</description>
        <in-parameters>
            <parameter name="lcId" required="true"/>
            <parameter name="creditAgreementId"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="!lc"><return error="true" message="LC not found"/></if>
            
            <service-call name="moqui.trade.finance.CbsIntegrationServices.check#CreditLimit"
                in-map="[partyId:lc.applicantPartyId, creditAgreementId:creditAgreementId]" out-map="limitOut"/>
            
            <if condition="limitOut.availableLimit != null">
                <service-call name="update#moqui.trade.finance.LetterOfCredit"
                    in-map="[lcId:lcId, availableCreditLimit:limitOut.availableLimit]"/>
                <service-call name="create#moqui.trade.finance.LcHistory"
                    in-map="[lcId:lcId, changeType:'Update', fieldName:'availableCreditLimit', 
                             newValue:limitOut.availableLimit, changedByUserId:ec.user.userId,
                             comments:'Credit limit updated from CBS']"/>
            </if>
        </actions>
    </service>


    <!-- ========================================================= -->
    <!-- Charge Management Services                                -->
    <!-- ========================================================= -->

    <service verb="create" noun="LcCharge">
        <description>Manually adds a charge to an LC. Only allowed for Draft LCs.</description>
        <in-parameters>
            <auto-parameters entity-name="moqui.trade.finance.LcCharge" include="nonpk"/>
            <parameter name="lcId" required="true"/>
        </in-parameters>
        <out-parameters>
            <parameter name="chargeSeqId"/>
        </out-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="!lc"><return error="true" message="Letter of Credit not found."/></if>
            <if condition="lc.transactionStatusId != 'LcTxDraft'">
                <return error="true" message="Charges can only be modified for Draft LCs."/>
            </if>
            <service-call name="create#moqui.trade.finance.LcCharge" in-map="context" out-map="context"/>
        </actions>
    </service>

    <service verb="update" noun="LcCharge">
        <description>Updates an existing charge. Only allowed for Draft LCs.</description>
        <in-parameters>
            <auto-parameters entity-name="moqui.trade.finance.LcCharge" include="pk"/>
            <auto-parameters entity-name="moqui.trade.finance.LcCharge" include="nonpk"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="lc.transactionStatusId != 'LcTxDraft'">
                <return error="true" message="Charges can only be modified for Draft LCs."/>
            </if>
            <service-call name="update#moqui.trade.finance.LcCharge" in-map="context"/>
        </actions>
    </service>

    <service verb="delete" noun="LcCharge">
        <description>Removes a charge. Only allowed for Draft LCs.</description>
        <in-parameters>
            <auto-parameters entity-name="moqui.trade.finance.LcCharge" include="pk"/>
        </in-parameters>
        <actions>
            <entity-find-one entity-name="moqui.trade.finance.LetterOfCredit" value-field="lc"/>
            <if condition="lc.transactionStatusId != 'LcTxDraft'">
                <return error="true" message="Charges can only be modified for Draft LCs."/>
            </if>
            <service-call name="delete#moqui.trade.finance.LcCharge" in-map="context"/>
        </actions>
    </service>

</services>
