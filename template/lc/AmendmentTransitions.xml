<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        always-use-full-path="true">
    <transition name="CreateAmendment">
        <service-call name="moqui.trade.finance.AmendmentServices.create#LcAmendment" in-map="context" out-map="context"/>
        <default-response url="//${appRoot}/ImportLc/Amendment/AmendmentDetail" parameter-map="[lcId:lcId, amendmentSeqId:amendmentSeqId]"/>
    </transition>
    <widgets></widgets>
</screen>
